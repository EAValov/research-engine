# Copy this file to .env before running docker compose or podman compose.

# Released app image tag from GHCR.
RESEARCH_ENGINE_TAG=latest

# Public Web UI port on your machine.
WEBUI_HOST_PORT=8090

# Local app data stores.
RESEARCH_DB_NAME=research
RESEARCH_DB_USER=research
RESEARCH_DB_PASSWORD=change-this-postgres-password
RESEARCH_API_KEY=change-this-api-key

# External chat backend.
# If you run vLLM separately with docker run or another compose project,
# point this URL at that service.
CHAT_ENDPOINT=http://your-chat-backend:8000/v1
CHAT_API_KEY=change-this-chat-api-key
CHAT_MODEL_ID=your-chat-model
CHAT_MAX_CONTEXT_LENGTH=32768

# External Firecrawl backend.
# If you run Firecrawl separately with docker run or another compose project,
# point this URL at that service.
FIRECRAWL_BASE_URL=http://your-firecrawl-backend:3002
FIRECRAWL_API_KEY=change-this-firecrawl-api-key
FIRECRAWL_TIMEOUT_SECONDS=600

# Local Ollama embeddings service started by compose.
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL_ID=qwen3-embedding:0.6b
EMBEDDING_DIMENSION=1024
