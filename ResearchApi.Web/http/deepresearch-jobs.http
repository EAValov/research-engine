@baseUrl = http://localhost:5000
@token = CHANGEME

### Create a research job without overrides
POST {{baseUrl}}/api/research/jobs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "query": "What are the latest developments in AI research?",
  "clarifications": [
    {
      "question": "What time period should we focus on?",
      "answer": "Last 6 months"
    }
  ],
  "breadth": 3,
  "depth": 2,
  "language": "en",
  "region": "US",
  "webhook": {
    "url": "https://example.com/webhook",
    "secret": "my-secret-key"
  }
}

### Create a research job with auto-computed parameters
POST {{baseUrl}}/api/research/jobs
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "query": "How does climate change affect agriculture?",
  "clarifications": null,
  "breadth": null,
  "depth": null,
  "language": null,
  "region": null,
  "webhook": null
}

### Get job status
GET {{baseUrl}}/api/research/jobs/{{jobId}}
Authorization: Bearer {{token}}

### List events for a job
GET {{baseUrl}}/api/research/jobs/{{jobId}}/events
Authorization: Bearer {{token}}

### Stream events (requires SSE support)
GET {{baseUrl}}/api/research/jobs/{{jobId}}/events/stream
Authorization: Bearer {{token}}
