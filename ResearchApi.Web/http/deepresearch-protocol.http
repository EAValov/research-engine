@baseUrl = http://localhost:5000
@token = CHANGEME

### Generate clarification questions
POST {{baseUrl}}/api/research/protocol/clarifications
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "query": "What are the latest developments in AI research?",
  "includeConfigureQuestions": true
}

### Select protocol parameters
POST {{baseUrl}}/api/research/protocol/parameters
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "query": "How does climate change affect agriculture?",
  "clarifications": [
    {
      "question": "What time period should we focus on?",
      "answer": "Last 6 months"
    }
  ],
  "overrides": {
    "breadth": 3,
    "depth": 2,
    "language": "en",
    "region": "US"
  }
}
