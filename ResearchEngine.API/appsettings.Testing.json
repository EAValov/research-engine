{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Fatal"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Fatal",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}"
        }
      }
    ]
  }
}
