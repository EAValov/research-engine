{
  "AllowedHosts": "*",
  "AppVersion": "dev",
  "ConnectionStrings": {
    "ResearchDb": "Host=postgres;Port=5432;Database=research;Username=research;Password=research-password",
    "HangfireDb": "Host=postgres;Port=5432;Database=research;Username=research;Password=research-password"
  },
  "FirecrawlOptions": {
    "BaseUrl": "http://firecrawl:3002",
    "ApiKey": "random-key-here",
    "HttpClientTimeoutSeconds": 600
  },
  "ChatConfig": {
    "Endpoint": "http://vllm:8000/v1",
    "ApiKey": "random-key-here",
    "ModelId": "nvidia/Qwen3-30B-A3B-NVFP4",
    "MaxOutputTokens": 2048
  },
  "EmbeddingConfig": {
    "Endpoint": "http://ollama:11434/v1",
    "ApiKey": "random-key-here",
    "ModelId": "Qwen/Qwen3-Embedding-0.6B",
    "Dimension": 1024
  },
  "ResearchOrchestratorConfig": {
    "LimitSearches": 5,
    "MaxUrlParallelism": 1,
    "MaxUrlsPerSerpQuery": 20,
    "DefaultDiscoveryMode": "Auto"
  },
  "LearningSimilarityOptions": {
    "MinImportance": 0.65,
    "DiversityMaxPerUrl": 3,
    "DiversityMaxTextSimilarity": 0.85,
    "MaxLearningsPerSegment": 8,
    "MinLearningsPerSegment": 5,
    "GroupAssignSimilarityThreshold": 0.93,
    "GroupSearchTopK": 5,
    "MaxEvidenceLength": 20000
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "AuthenticationOptions": {
    "Enabled": true,
    "ApiKeys": [
      "RYCQlDNSFnJgUrOIZdnh4mlOghdkzhCntgeDjsJqCYFz7tou1F1bZi8oNJ4C0hav"
    ]
  },
  "ReleaseCheckOptions": {
    "Enabled": true,
    "RepositoryOwner": "EAValov",
    "RepositoryName": "research-engine",
    "SuccessCacheMinutes": 360,
    "FailureCacheMinutes": 30
  },
  "RedisEventBusOptions": {
     "ConnectionString": "redis:6379"
   },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
   "IpRateLimiting": {
    "Enabled":true,
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Forwarded-For",
    "ClientIdHeader": "X-ClientId",
    "DisableRateLimitHeaders": false,
    "GeneralRules": [
      { "Endpoint": "GET:/health/live", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/health/ready", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/openapi/*", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/scalar/*", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/hangfire*", "Period": "1m", "Limit": 60 },
      { "Endpoint": "*:/api/*", "Period": "1m", "Limit": 600 }
    ]
  },

  "IpRateLimitPolicies": {
    "IpRules": [
    ]
  }
}
