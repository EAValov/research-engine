@using ResearchEngine.Blazor.Api
@using ResearchEngine.Blazor.Components.Common
@using ResearchEngine.Blazor.Services
@inject LearningGroupFacade Groups

<div class="popover"
     id="@PopoverId"
     role="dialog"
     aria-label="Learning group"
     style="@Style"
     hidden="@(!IsOpen)"
     tabindex="-1"
     @ref="_popoverRef">
    <div class="popover-head">
        <div class="title">Representative</div>
        <button type="button" class="x" @onclick="Close" aria-label="Close">×</button>
    </div>

    @if (!IsOpen)
    {
        @* hidden *@
    }
    else if (_loading)
    {
        <div class="muted">Loading…</div>
    }
    else if (_error is not null)
    {
        <ErrorBanner Error="_error" OnRetry="LoadAsync" />
    }
    else if (_group is null)
    {
        <div class="muted">No group data available.</div>
        <div class="actions">
            <button type="button" class="primary" @onclick="OpenInLearnings">Open in Learnings</button>
        </div>
    }
    else
    {
        <div class="body">
            <div class="main">
                <div class="rep">@_group.RepresentativeLearningText</div>

                @if (!string.IsNullOrWhiteSpace(RepresentativeSourceUrl))
                {
                    <div class="source-row">
                        <span class="source-label">Source:</span>
                        <a class="source-link"
                           href="@RepresentativeSourceUrl"
                           target="_blank"
                           rel="noopener noreferrer"
                           title="@RepresentativeSourceUrl">
                            @GetLinkText(RepresentativeSourceUrl)
                        </a>
                    </div>
                }

                <div class="meta">
                    <span>Score: @_group.CanonicalImportanceScore.ToString("0.00")</span>
                    <span class="dot">•</span>
                    <span>Members: @_group.MemberCount</span>
                    <span class="dot">•</span>
                    <span>Sources: @_group.DistinctSourceCount</span>
                </div>
            </div>

            <div class="actions">
                <button type="button" class="primary" @onclick="OpenInLearnings">Open in Learnings</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public Guid LearningId { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string Style { get; set; } = "";
    [Parameter] public string PopoverId { get; set; } = "lg-popover";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Guid> OnOpenInLearnings { get; set; }

    private ElementReference _popoverRef;

    private bool _loading;
    private ApiError? _error;
    private LearningGroupCardDto? _group;
    private string? RepresentativeSourceUrl => GetRepresentativeSourceUrl(_group);

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        var res = await Groups.GetGroupAsync(LearningId);
        if (!res.IsSuccess)
        {
            _error = res.Error;
            _group = null;
            _loading = false;
            return;
        }

        _group = res.Data;
        _loading = false;
    }

    private Task Close() => OnClose.InvokeAsync();

    private Task OpenInLearnings()
        => OnOpenInLearnings.InvokeAsync(LearningId);

    private static string? GetRepresentativeSourceUrl(LearningGroupCardDto? group)
    {
        if (group?.Evidence is null)
            return null;

        foreach (var ev in group.Evidence.OrderByDescending(x => x.ImportanceScore))
        {
            var reference = (ev.SourceReference ?? string.Empty).Trim();
            if (TryNormalizeHttpUrl(reference, out var normalized))
                return normalized;
        }

        return null;
    }

    private static bool TryNormalizeHttpUrl(string text, out string normalized)
    {
        normalized = string.Empty;
        if (!Uri.TryCreate(text, UriKind.Absolute, out var uri))
            return false;

        if (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps)
            return false;

        normalized = uri.GetComponents(UriComponents.HttpRequestUrl, UriFormat.SafeUnescaped);
        return true;
    }

    private static string GetLinkText(string url)
    {
        const int maxLength = 56;
        if (string.IsNullOrWhiteSpace(url) || url.Length <= maxLength)
            return url;

        if (Uri.TryCreate(url, UriKind.Absolute, out var uri) && !string.IsNullOrWhiteSpace(uri.Host))
            return uri.Host;

        return url;
    }
}
