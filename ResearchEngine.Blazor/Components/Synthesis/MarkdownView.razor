@using Markdig
@using Ganss.Xss
@using System.Globalization
@using ResearchEngine.Blazor.Api
@using ResearchEngine.Blazor.Services
@inject IJSRuntime JS
@inject LearningGroupFacade Groups

<div class="md-wrap" @ref="_containerRef">
    <div class="md" @key="_cacheKey">
        @((MarkupString)_html)
    </div>

    <LearningGroupPopover LearningId="_activeLearningId"
                          IsOpen="_popoverOpen"
                          Style="@_popoverStyle"
                          PopoverId="@PopoverElementId"
                          OnClose="ClosePopover"
                          OnOpenInLearnings="OpenInLearningsInternal" />
</div>

@code {
    [Parameter, EditorRequired] public string Markdown { get; set; } = string.Empty;

    // Bubble up action to JobDetailPage
    [Parameter] public EventCallback<Guid> OnOpenInLearnings { get; set; }

    private ElementReference _containerRef;

    private string _lastMarkdown = string.Empty;
    private string _html = string.Empty;
    private string _cacheKey = Guid.NewGuid().ToString("N");

    private static readonly MarkdownPipeline Pipeline = Citations.CreatePipelineWithCitations();
    private static readonly HtmlSanitizer Sanitizer = CreateSanitizer();

    private DotNetObjectReference<MarkdownView>? _dotNetRef;

    private const string PopoverElementId = "lg-popover";

    private bool _popoverOpen;
    private bool _popoverPinned;
    private Guid _activeLearningId = Guid.Empty;
    private string _popoverStyle = "";

    protected override async Task OnParametersSetAsync()
    {
        var md = Markdown ?? string.Empty;

        if (ReferenceEquals(md, _lastMarkdown) || md == _lastMarkdown)
            return;

        _lastMarkdown = md;

        var renderedMarkdown = await BuildDisplayMarkdownAsync(md);

        // Render markdown -> HTML (tokens included)
        var rawHtml = Markdig.Markdown.ToHtml(renderedMarkdown, Pipeline);

        // Sanitize
        _html = Sanitizer.Sanitize(rawHtml);

        // Update render key
        _cacheKey = Guid.NewGuid().ToString("N");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _dotNetRef ??= DotNetObjectReference.Create(this);

        // Wire citation interactions each render (JS keeps a WeakMap to avoid double wiring)
        try
        {
            await JS.InvokeVoidAsync("researchEngine.citations.wire", _containerRef, _dotNetRef);
        }
        catch { }

        // Register/unregister global close handlers based on popover state
        try
        {
            if (_popoverOpen)
                await JS.InvokeVoidAsync("researchEngine.citations.registerGlobalClose", _dotNetRef, PopoverElementId);
            else
                await JS.InvokeVoidAsync("researchEngine.citations.unregisterGlobalClose");
        }
        catch { }

        // Render fenced mermaid code blocks as diagrams.
        try
        {
            await JS.InvokeVoidAsync("researchEngine.mermaid.render", _containerRef);
        }
        catch { }
    }

    private async Task PrefetchSafeAsync(IReadOnlyList<Guid> ids)
    {
        if (ids.Count == 0) return;
        try { await Groups.PrefetchGroupsAsync(ids); } catch { }
    }

    private async Task<string> BuildDisplayMarkdownAsync(string markdown)
    {
        var orderedIds = Citations.ExtractLearningIdsInAppearanceOrder(markdown);
        if (orderedIds.Count == 0)
            return markdown;

        await PrefetchSafeAsync(orderedIds);

        var sourceIndexByKey = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var citationIndexByLearningId = new Dictionary<Guid, int>();
        var sourceByIndex = new Dictionary<int, string>();

        var nextIndex = 1;

        foreach (var learningId in orderedIds)
        {
            LearningGroupCardDto? group = null;
            if (Groups.TryGetCached(learningId, out var cached))
                group = cached;

            var groupKey = group?.GroupId ?? learningId;
            var sourceReference = GetTopReference(group, learningId);
            var sourceKey = BuildSourceKey(sourceReference, groupKey);

            if (!sourceIndexByKey.TryGetValue(sourceKey, out var index))
            {
                index = nextIndex++;
                sourceIndexByKey[sourceKey] = index;
                sourceByIndex[index] = sourceReference;
            }

            citationIndexByLearningId[learningId] = index;
        }

        var rewritten = Citations.RewriteLearningCitations(markdown, learningId =>
        {
            if (!citationIndexByLearningId.TryGetValue(learningId, out var index))
                return null;

            return index.ToString(CultureInfo.InvariantCulture);
        });

        if (sourceByIndex.Count == 0)
            return rewritten;

        var sources = sourceByIndex
            .OrderBy(x => x.Key)
            .Select(x => $"{x.Key}. {x.Value}")
            .ToList();

        return $"{rewritten}\n\n## Sources\n\n{string.Join("\n", sources)}";
    }

    private static string GetTopReference(LearningGroupCardDto? group, Guid learningId)
    {
        if (group?.Evidence is not null)
        {
            foreach (var ev in group.Evidence)
            {
                var reference = (ev.SourceReference ?? string.Empty).Trim();
                if (string.IsNullOrWhiteSpace(reference))
                    continue;

                if (IsHttpUrl(reference))
                    return reference;
            }

            var first = group.Evidence
                .Select(x => (x.SourceReference ?? string.Empty).Trim())
                .FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));

            if (!string.IsNullOrWhiteSpace(first))
                return first;
        }

        return $"learning:{learningId:N}";
    }

    private static bool IsHttpUrl(string text)
    {
        if (!Uri.TryCreate(text, UriKind.Absolute, out var uri))
            return false;

        return uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps;
    }

    private static bool TryNormalizeHttpUrl(string text, out string normalized)
    {
        normalized = string.Empty;
        if (!Uri.TryCreate(text, UriKind.Absolute, out var uri))
            return false;

        if (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps)
            return false;

        normalized = uri.GetComponents(UriComponents.HttpRequestUrl, UriFormat.SafeUnescaped).TrimEnd('/');
        if (string.IsNullOrWhiteSpace(normalized))
            normalized = uri.GetComponents(UriComponents.HttpRequestUrl, UriFormat.SafeUnescaped);

        return true;
    }

    private static string BuildSourceKey(string sourceReference, Guid groupKey)
    {
        var trimmed = (sourceReference ?? string.Empty).Trim();
        if (TryNormalizeHttpUrl(trimmed, out var normalizedUrl))
            return $"url:{normalizedUrl}";

        if (!string.IsNullOrWhiteSpace(trimmed))
            return $"ref:{trimmed}";

        return $"group:{groupKey:N}";
    }

    // rect: { left, top, right, bottom, width, height, vw, vh }
    [JSInvokable]
    public Task OnCitationActivate(string learningId, string reason, object rect)
    {
        if (_popoverPinned)
            return Task.CompletedTask;

        if (!Guid.TryParse(learningId, out var id))
            return Task.CompletedTask;

        _activeLearningId = id;
        _popoverOpen = true;
        _popoverStyle = ComputePopoverStyle(rect);

        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnCitationDeactivate(string reason)
    {
        if (_popoverPinned)
            return Task.CompletedTask;

        if (reason == "hover")
        {
            _popoverOpen = false;
            return InvokeAsync(StateHasChanged);
        }

        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnCitationToggle(string learningId, object rect)
    {
        if (!Guid.TryParse(learningId, out var id))
            return Task.CompletedTask;

        // If a citation is only hover-open, first click should pin it open.
        if (_popoverOpen && _activeLearningId == id)
        {
            if (_popoverPinned)
            {
                _popoverOpen = false;
                _popoverPinned = false;
            }
            else
            {
                _popoverPinned = true;
                _popoverStyle = ComputePopoverStyle(rect);
            }
            return InvokeAsync(StateHasChanged);
        }

        _activeLearningId = id;
        _popoverOpen = true;
        _popoverPinned = true;
        _popoverStyle = ComputePopoverStyle(rect);

        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnRequestClosePopover(string reason)
    {
        _popoverOpen = false;
        _popoverPinned = false;
        return InvokeAsync(StateHasChanged);
    }

    private Task ClosePopover()
    {
        _popoverOpen = false;
        _popoverPinned = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task OpenInLearningsInternal(Guid learningId)
    {
        _popoverOpen = false;
        _popoverPinned = false;
        await OnOpenInLearnings.InvokeAsync(learningId);
    }

    private static string ComputePopoverStyle(object rectObj)
    {
        if (rectObj is not System.Text.Json.JsonElement el || el.ValueKind != System.Text.Json.JsonValueKind.Object)
            return "left: 12px; top: 12px;";

        double left = Get(el, "left");
        double bottom = Get(el, "bottom");
        double vw = Get(el, "vw");

        var x = Math.Min(Math.Max(12, left), Math.Max(12, vw - 540)); // 520 + padding
        var y = bottom + 8;

        return $"left: {x:0}px; top: {y:0}px;";
    }

    private static double Get(System.Text.Json.JsonElement el, string name)
    {
        if (!el.TryGetProperty(name, out var p)) return 0;
        return p.ValueKind == System.Text.Json.JsonValueKind.Number ? p.GetDouble() : 0;
    }

    private static HtmlSanitizer CreateSanitizer()
    {
        var s = new HtmlSanitizer();

        // Allow our citation tokens
        s.AllowedTags.Add("button");
        s.AllowedAttributes.Add("data-lrn");
        s.AllowedAttributes.Add("class");
        s.AllowedAttributes.Add("type");
        s.AllowedAttributes.Add("aria-label");
        s.AllowedAttributes.Add("aria-expanded");

        // Keep links safe
        s.AllowedSchemes.Clear();
        s.AllowedSchemes.Add("http");
        s.AllowedSchemes.Add("https");
        s.AllowedSchemes.Add("mailto");

        // Strip style attributes
        s.AllowedAttributes.Remove("style");

        return s;
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("researchEngine.citations.unregisterGlobalClose"); } catch { }
        _dotNetRef?.Dispose();
    }
}
