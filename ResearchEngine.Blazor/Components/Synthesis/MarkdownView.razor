@using Markdig
@using Ganss.Xss
@using ResearchEngine.Blazor.Services
@inject IJSRuntime JS
@inject LearningGroupFacade Groups

<div class="md-wrap" @ref="_containerRef">
    <div class="md" @key="_cacheKey">
        @((MarkupString)_html)
    </div>

    <LearningGroupPopover LearningId="_activeLearningId"
                          IsOpen="_popoverOpen"
                          Style="@_popoverStyle"
                          PopoverId="@PopoverElementId"
                          OnClose="ClosePopover"
                          OnOpenInLearnings="OpenInLearningsInternal" />
</div>

@code {
    [Parameter, EditorRequired] public string Markdown { get; set; } = string.Empty;

    // Bubble up action to JobDetailPage
    [Parameter] public EventCallback<Guid> OnOpenInLearnings { get; set; }

    private ElementReference _containerRef;

    private string _lastMarkdown = string.Empty;
    private string _html = string.Empty;
    private string _cacheKey = Guid.NewGuid().ToString("N");

    private static readonly MarkdownPipeline Pipeline = Citations.CreatePipelineWithCitations();
    private static readonly HtmlSanitizer Sanitizer = CreateSanitizer();

    private DotNetObjectReference<MarkdownView>? _dotNetRef;

    private const string PopoverElementId = "lg-popover";

    private bool _popoverOpen;
    private Guid _activeLearningId = Guid.Empty;
    private string _popoverStyle = "";

    protected override void OnParametersSet()
    {
        var md = Markdown ?? string.Empty;

        if (ReferenceEquals(md, _lastMarkdown) || md == _lastMarkdown)
            return;

        _lastMarkdown = md;

        // Render markdown -> HTML (tokens included)
        var rawHtml = Markdig.Markdown.ToHtml(md, Pipeline);

        // Sanitize
        _html = Sanitizer.Sanitize(rawHtml);

        // Update render key
        _cacheKey = md.Length.ToString();

        // Prefetch groups (non-blocking)
        var ids = Citations.ExtractLearningIds(md);
        _ = PrefetchSafeAsync(ids);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _dotNetRef ??= DotNetObjectReference.Create(this);

        // Wire citation interactions each render (JS keeps a WeakMap to avoid double wiring)
        try
        {
            await JS.InvokeVoidAsync("researchEngine.citations.wire", _containerRef, _dotNetRef);
        }
        catch { }

        // Register/unregister global close handlers based on popover state
        try
        {
            if (_popoverOpen)
                await JS.InvokeVoidAsync("researchEngine.citations.registerGlobalClose", _dotNetRef, PopoverElementId);
            else
                await JS.InvokeVoidAsync("researchEngine.citations.unregisterGlobalClose");
        }
        catch { }
    }

    private async Task PrefetchSafeAsync(IReadOnlyList<Guid> ids)
    {
        if (ids.Count == 0) return;
        try { await Groups.PrefetchGroupsAsync(ids); } catch { }
    }

    // rect: { left, top, right, bottom, width, height, vw, vh }
    [JSInvokable]
    public Task OnCitationActivate(string learningId, string reason, object rect)
    {
        if (!Guid.TryParse(learningId, out var id))
            return Task.CompletedTask;

        // Open on hover/focus (best-effort)
        _activeLearningId = id;
        _popoverOpen = true;
        _popoverStyle = ComputePopoverStyle(rect);

        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnCitationDeactivate(string reason)
    {
        // For hover leave: close only if user didn’t click-open.
        // Keep simple: close on hover-leave unless focus is inside popover; global handler will close otherwise.
        if (reason == "hover")
        {
            _popoverOpen = false;
            return InvokeAsync(StateHasChanged);
        }
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnCitationToggle(string learningId, object rect)
    {
        if (!Guid.TryParse(learningId, out var id))
            return Task.CompletedTask;

        if (_popoverOpen && _activeLearningId == id)
        {
            _popoverOpen = false;
            return InvokeAsync(StateHasChanged);
        }

        _activeLearningId = id;
        _popoverOpen = true;
        _popoverStyle = ComputePopoverStyle(rect);

        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnRequestClosePopover(string reason)
    {
        _popoverOpen = false;
        return InvokeAsync(StateHasChanged);
    }

    private Task ClosePopover()
    {
        _popoverOpen = false;
        return InvokeAsync(StateHasChanged);
    }

    private async Task OpenInLearningsInternal(Guid learningId)
    {
        _popoverOpen = false;
        await OnOpenInLearnings.InvokeAsync(learningId);
    }

    private static string ComputePopoverStyle(object rectObj)
    {
        // rectObj is a JS object; in Blazor WASM it arrives as JsonElement.
        // We'll do minimal parsing via System.Text.Json.
        if (rectObj is not System.Text.Json.JsonElement el || el.ValueKind != System.Text.Json.JsonValueKind.Object)
            return "left: 12px; top: 12px;";

        double left = Get(el, "left");
        double bottom = Get(el, "bottom");
        double vw = Get(el, "vw");

        // Prefer placing popover below the token; clamp to viewport
        var x = Math.Min(Math.Max(12, left), Math.Max(12, vw - 540)); // 520 + padding
        var y = bottom + 8;

        return $"left: {x:0}px; top: {y:0}px;";
    }

    private static double Get(System.Text.Json.JsonElement el, string name)
    {
        if (!el.TryGetProperty(name, out var p)) return 0;
        return p.ValueKind == System.Text.Json.JsonValueKind.Number ? p.GetDouble() : 0;
    }

    private static HtmlSanitizer CreateSanitizer()
    {
        var s = new HtmlSanitizer();

        // Allow our citation tokens
        s.AllowedTags.Add("button");
        s.AllowedAttributes.Add("data-lrn");
        s.AllowedAttributes.Add("class");
        s.AllowedAttributes.Add("type");
        s.AllowedAttributes.Add("aria-label");
        s.AllowedAttributes.Add("aria-expanded");

        // Keep links safe
        s.AllowedSchemes.Clear();
        s.AllowedSchemes.Add("http");
        s.AllowedSchemes.Add("https");
        s.AllowedSchemes.Add("mailto");

        // Strip style attributes
        s.AllowedAttributes.Remove("style");

        return s;
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("researchEngine.citations.unregisterGlobalClose"); } catch { }
        _dotNetRef?.Dispose();
    }
}
