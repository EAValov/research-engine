FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY . .
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python-is-python3 \
    && rm -rf /var/lib/apt/lists/*
RUN dotnet workload install wasm-tools
RUN dotnet restore ResearchEngine.Blazor.csproj /p:GenerateApiClientOnBuild=false
RUN dotnet publish ResearchEngine.Blazor.csproj -c Release -o /app/publish /p:GenerateApiClientOnBuild=false

FROM caddy:2.9-alpine AS final
WORKDIR /srv

COPY --from=build /app/publish/wwwroot/ /srv/
COPY Caddyfile /etc/caddy/Caddyfile
COPY entrypoint.sh /usr/local/bin/entrypoint.sh

RUN chmod +x /usr/local/bin/entrypoint.sh

ENV BLAZOR_PORT=8081
ENV API_BASE_URL=http://localhost:8090

EXPOSE 8081

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
