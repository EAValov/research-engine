{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ResearchDb": "Host=nuq-postgres;Port=5432;Database=research;Username=firecrawl;Password=firecrawl",
    "HangfireDb": "Host=nuq-postgres;Port=5432;Database=jobs;Username=firecrawl;Password=firecrawl"
  },
  "FirecrawlOptions": {
    "BaseUrl": "http://firecrawl:3002",
    "HttpClientTimeoutSeconds": 600
  },
  "ChatConfig": {
    "Endpoint": "http://vllm:8000/v1",
    "ApiKey": "random-key-here",
    "ModelId": "NVFP4/Qwen3-30B-A3B-Instruct-2507-FP4"
  },
  "EmbeddingConfig": {
    "Endpoint": "http://vllm-embeddings:8001/v1",
    "ApiKey": "random-key-here",
    "ModelId": "Qwen/Qwen3-Embedding-0.6B",
    "Dimension": 1024
  },
  "ResearchOrchestratorConfig": {
    "LimitSearches": 5,
    "MaxUrlParallelism": 1,
    "MaxUrlsPerSerpQuery": 20
  },
  "LearningSimilarityOptions": {
    "LocalMinImportance": 0.4,
    "GlobalMinImportance": 0.65,
    "MinLocalFractionForNoGlobal": 0.75,
    "DiversityMaxPerUrl": 3,
    "DiversityMaxTextSimilarity": 0.85
  },
  "BearerAuthenticationOptions": {
    "Enabled": true,
    "BearerTokens": [
      "9h32F2fNuwMQL0OUujpUoIF6l8S/lGPOM1ylNhH+MKQ="
    ]
  },
 "RedisEventBusOptions": {
    "ConnectionString": "redis:6379"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app.log",
          "rollingInterval": "Hour",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:dd/MM/yyyy HH:mm:ss ffff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
   "IpRateLimiting": {
    "Enabled":true,
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Forwarded-For",
    "ClientIdHeader": "X-ClientId",
    "DisableRateLimitHeaders": false,
    "GeneralRules": [
      { "Endpoint": "POST:/api/research/jobs", "Period": "1m", "Limit": 10 },
      { "Endpoint": "GET:/api/research/jobs/*", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/api/research/jobs/*/sources", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/api/research/jobs/*/learnings", "Period": "1m", "Limit": 120 },
      { "Endpoint": "POST:/api/research/jobs/*/learnings", "Period": "1m", "Limit": 30 },
      { "Endpoint": "GET:/api/research/jobs/*/syntheses/latest", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/api/research/syntheses/*", "Period": "1m", "Limit": 120 },
      { "Endpoint": "POST:/api/research/jobs/*/syntheses", "Period": "1m", "Limit": 20 },
      { "Endpoint": "PUT:/api/research/syntheses/*/overrides/sources", "Period": "1m", "Limit": 30 },
      { "Endpoint": "PUT:/api/research/syntheses/*/overrides/learnings", "Period": "1m", "Limit": 30 },
      { "Endpoint": "POST:/api/research/syntheses/*/run", "Period": "1m", "Limit": 10 },
      { "Endpoint": "GET:/api/research/jobs/*/events", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/api/research/jobs/*/events/stream", "Period": "1m", "Limit": 10 },
      { "Endpoint": "GET:/health/live", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/health/ready", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/openapi/*", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/scalar/*", "Period": "1m", "Limit": 120 },
      { "Endpoint": "GET:/hangfire*", "Period": "1m", "Limit": 60 },
      { "Endpoint": "*:/api/research/*", "Period": "1m", "Limit": 600 }
    ]
  },

  "IpRateLimitPolicies": {
    "IpRules": [
    ]
  }
}
