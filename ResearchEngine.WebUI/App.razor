@using ResearchEngine.WebUI.State
@using ResearchEngine.WebUI.Services
@inject AppStateStore AppState
@inject ResearchEngine.WebUI.Services.ApiConnectionSettings ApiConnection

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="#mainContent" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <p>Sorry, there’s nothing at this address.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    protected override async Task OnInitializedAsync()
    {
        await AppState.InitializeAsync();

        var saved = AppState.GetApiSettings();

        var apiBaseUrl = string.IsNullOrWhiteSpace(saved.BaseUrl) || ShouldPreferFallback(saved.BaseUrl, ApiConnection.FallbackApiBaseUrl)
            ? ApiConnection.FallbackApiBaseUrl
            : saved.BaseUrl;

        var bearerToken = saved.BearerToken ?? string.Empty;
        var authEnabled = saved.AuthEnabled;

        if (ApiConnection.TryApply(apiBaseUrl, bearerToken, authEnabled))
        {
            if (!string.Equals(saved.BaseUrl, apiBaseUrl, StringComparison.Ordinal)
                || !string.Equals(saved.BearerToken ?? string.Empty, bearerToken, StringComparison.Ordinal)
                || saved.AuthEnabled != authEnabled)
            {
                AppState.SetApiSettings(apiBaseUrl, bearerToken, authEnabled);
            }
        }
        else
        {
            ApiConnection.TryApply(ApiConnection.FallbackApiBaseUrl, bearerToken, authEnabled);
            AppState.SetApiSettings(ApiConnection.ApiBaseUrl, bearerToken, authEnabled);
        }
    }

    private static bool ShouldPreferFallback(string? savedBaseUrl, string fallbackBaseUrl)
    {
        var normalizedSaved = ApiConnectionSettings.NormalizeBaseUrl(savedBaseUrl);
        var normalizedFallback = ApiConnectionSettings.NormalizeBaseUrl(fallbackBaseUrl);

        if (normalizedSaved is null || normalizedFallback is null)
            return false;

        if (string.Equals(normalizedSaved, normalizedFallback, StringComparison.OrdinalIgnoreCase))
            return false;

        if (!ApiConnectionSettings.IsLocalDeploymentUrl(normalizedSaved)
            || !ApiConnectionSettings.IsLocalDeploymentUrl(normalizedFallback))
        {
            return false;
        }

        if (!Uri.TryCreate(normalizedSaved, UriKind.Absolute, out var savedUri)
            || !Uri.TryCreate(normalizedFallback, UriKind.Absolute, out var fallbackUri))
        {
            return false;
        }

        return savedUri.IsLoopback != fallbackUri.IsLoopback;
    }
}
