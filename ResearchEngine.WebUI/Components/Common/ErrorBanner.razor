@using ResearchEngine.WebUI.Services

@if (Error is not null)
{
    <div class="err" role="alert" aria-live="assertive">
        <div class="msg">
            <div class="title">@TitleFor(Error)</div>
            <div class="text">@Error.Message</div>
            @if (!string.IsNullOrWhiteSpace(Error.Details))
            {
                <details class="details">
                    <summary>Details</summary>
                    <pre class="pre">@Error.Details</pre>
                </details>
            }
        </div>

        @if (OnRetry.HasDelegate)
        {
            <button type="button" class="retry" @onclick="OnRetry" aria-label="Retry">
                Retry
            </button>
        }
    </div>
}

@code {
    [Parameter] public ApiError? Error { get; set; }
    [Parameter] public EventCallback OnRetry { get; set; }

    private static string TitleFor(ApiError e) => e.Kind switch
    {
        ApiErrorKind.Auth => "Auth error",
        ApiErrorKind.Validation => "Validation error",
        ApiErrorKind.Network => "Network error",
        ApiErrorKind.Http => "Server error",
        _ => "Error"
    };
}

<style>
.err {
    border: 1px solid #e6e6e6;
    border-left: 4px solid var(--text);
    border-radius: 12px;
    padding: 12px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin: 12px 0;
    background: #fff;
}
.title { font-weight: 700; margin-bottom: 4px; }
.text { color: #222; }
.retry {
    align-self: start;
    border: 1px solid #e6e6e6;
    background: #fff;
    border-radius: 10px;
    padding: 6px 10px;
    cursor: pointer;
}
.retry:focus-visible { outline: 2px solid var(--text); outline-offset: 2px; }
.details { margin-top: 8px; }
.pre { white-space: pre-wrap; word-break: break-word; margin: 8px 0 0; }
</style>
