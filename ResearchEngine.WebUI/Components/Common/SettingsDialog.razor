<button type="button"
        class="settings-toggle"
        @onclick="OpenSettingsAsync"
        aria-label="Open app settings"
        title="Open app settings">
    Settings
</button>

@if (_settingsOpen)
{
    <div class="settings-overlay" @onclick="CloseSettings">
        <section class="settings-dialog"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="settingsTitle"
                 @onclick:stopPropagation="true">
                <div class="settings-head">
                    <div>
                        <h2 id="settingsTitle">Settings</h2>
                        <p class="settings-subtitle">ResearchEngine API, Chat LLM settings, crawl settings, search defaults, and learning similarity.</p>
                    </div>
                    <button type="button" class="close-btn" @onclick="CloseSettings" aria-label="Close settings">×</button>
                </div>

            <div class="settings-body">
                <section class="settings-group">
                    <div class="settings-group-head">
                        <h3>ResearchEngine API</h3>
                        <p>Connection details stored in this browser session.</p>
                    </div>

                    <div class="settings-grid">
                        <label class="settings-field settings-field-full">
                            <span class="settings-label-row">
                                <span>Endpoint</span>
                                <span class="settings-help" title="Absolute base URL for API requests.">Base API address</span>
                            </span>
                            <input class="@GetInputClass("Api.BaseUrl")"
                                   value="@_draftApiBaseUrl"
                                   @oninput="OnApiBaseUrlChanged"
                                   placeholder="https://api.example.com" />
                            @if (TryGetFieldError("Api.BaseUrl", out var apiUrlError))
                            {
                                <span class="settings-field-error">@apiUrlError</span>
                            }
                        </label>

                        <div class="settings-field settings-field-full settings-inline-row">
                            <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Write-only API key</span>
                                <span class="settings-help" title="API key used for authenticated API requests and sent as Authorization: Bearer &lt;key&gt;.">Leave blank to keep current key</span>
                            </span>
                            <input class="settings-input"
                                   value="@_draftApiKey"
                                   @oninput="OnApiKeyChanged"
                                   type="password"
                                   disabled="@(!_draftApiAuthEnabled)"
                                   placeholder="@(_baselineApiHasKey ? "Leave blank to keep current key" : "Enter API key")" />
                            <div class="settings-test-result" aria-live="polite">
                                @if (HasApiConnectionTestFeedback)
                                {
                                    <span class="@GetTestBadgeClass(_apiConnectionTestStatus)"
                                          title="@_apiConnectionTestMessage">
                                        @GetTestBadgeLabel(_apiConnectionTestStatus)
                                    </span>
                                    <span class="@GetTestFeedbackClass(_apiConnectionTestStatus)"
                                          title="@_apiConnectionTestMessage">
                                        @_apiConnectionTestMessage
                                    </span>
                                }
                            </div>
                            </label>

                            <div class="settings-inline-actions">
                                <div class="settings-inline-controls">
                                    <label class="settings-switch">
                                        <input type="checkbox"
                                               checked="@_draftApiAuthEnabled"
                                               @onchange="OnApiAuthChanged" />
                                        <span title="Include the API key on API requests using the Bearer authorization scheme.">API Auth</span>
                                    </label>

                                    <button type="button"
                                            class="secondarybtn"
                                            @onclick="TestApiConnectionAsync"
                                            disabled="@(!CanTestApiConnection)">
                                        @(_testingApiConnection ? "Testing..." : "Test")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="settings-group">
                    <div class="settings-group-head">
                        <h3>Chat LLM Settings</h3>
                        <p>Runtime chat settings for the connected API. Leave the API key blank to keep the current secret.</p>
                    </div>

                    <div class="settings-grid">
                        <label class="settings-field settings-field-full">
                            <span class="settings-label-row">
                                <span>Endpoint</span>
                                <span class="settings-help" title="Absolute OpenAI-compatible chat endpoint, usually ending with /v1.">Chat API URL</span>
                            </span>
                            <input class="@GetInputClass("ChatConfig.Endpoint")"
                                   value="@_draftChatConfig.Endpoint"
                                   @oninput="OnChatEndpointChanged"
                                   disabled="@IsRuntimeSettingsDisabled"
                                   placeholder="https://chat.example.com/v1" />
                            @if (TryGetFieldError("ChatConfig.Endpoint", out var chatEndpointError))
                            {
                                <span class="settings-field-error">@chatEndpointError</span>
                            }
                        </label>

                        <div class="settings-field settings-field-full settings-inline-row">
                            <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Write-only API key</span>
                                <span class="settings-help" title="Optional if the connected API already has a chat backend API key configured.">Leave blank to keep current key</span>
                            </span>
                            <input class="@GetInputClass("ChatConfig.ApiKey")"
                                   value="@_draftChatApiKey"
                                   @oninput="OnChatApiKeyChanged"
                                   type="password"
                                   disabled="@IsRuntimeSettingsDisabled"
                                   placeholder="@(_draftChatConfig.HasApiKey ? "Leave blank to keep current key" : "Enter backend API key")" />
                            @if (TryGetFieldError("ChatConfig.ApiKey", out var chatApiKeyError))
                            {
                                <span class="settings-field-error">@chatApiKeyError</span>
                            }
                            <div class="settings-test-result" aria-live="polite">
                                @if (HasChatApiTestFeedback)
                                {
                                    <span class="@GetTestBadgeClass(_chatApiTestStatus)"
                                          title="@_chatApiTestMessage">
                                        @GetTestBadgeLabel(_chatApiTestStatus)
                                    </span>
                                    <span class="@GetTestFeedbackClass(_chatApiTestStatus)"
                                          title="@_chatApiTestMessage">
                                        @_chatApiTestMessage
                                    </span>
                                }
                            </div>
                            </label>

                            <div class="settings-inline-actions">
                                <div class="settings-inline-controls">
                                    <button type="button"
                                            class="secondarybtn"
                                            @onclick="TestChatApiAsync"
                                            disabled="@(!CanTestChatApi || IsRuntimeSettingsDisabled)">
                                        @(_testingChatApi ? "Testing..." : "Test")
                                    </button>
                                </div>
                            </div>
                        </div>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Model id</span>
                                <span class="settings-help" title="Exact model id returned by the chat backend /models endpoint.">Backend model name</span>
                            </span>
                            <select class="@GetInputClass("ChatConfig.ModelId")"
                                    value="@_draftChatConfig.ModelId"
                                    @onchange="OnChatModelIdChanged"
                                    disabled="@IsChatModelSelectionDisabled">
                                @if (string.IsNullOrWhiteSpace(_draftChatConfig.ModelId))
                                {
                                    <option value="">Select a model</option>
                                }
                                @foreach (var modelId in ChatModelDropdownOptions)
                                {
                                    <option value="@modelId">@modelId</option>
                                }
                            </select>
                            @if (TryGetFieldError("ChatConfig.ModelId", out var chatModelError))
                            {
                                <span class="settings-field-error">@chatModelError</span>
                            }
                            else if (_loadingChatModelOptions)
                            {
                                <span class="settings-help-inline">Loading models from `/models`...</span>
                            }
                            else if (!string.IsNullOrWhiteSpace(_chatModelOptionsError))
                            {
                                <span class="settings-field-error">@_chatModelOptionsError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Max context length</span>
                                <span class="settings-help" title="Optional. Set this when the backend does not expose /tokenize. Minimum 10000.">Optional context window</span>
                            </span>
                            <input type="number" min="10000"
                                   class="@GetInputClass("ChatConfig.MaxContextLength")"
                                   value="@BindConverter.FormatValue(_draftChatConfig.MaxContextLength)"
                                   @oninput="OnChatMaxContextLengthChanged"
                                   disabled="@IsRuntimeSettingsDisabled"
                                   placeholder="32768" />
                            @if (TryGetFieldError("ChatConfig.MaxContextLength", out var chatContextError))
                            {
                                <span class="settings-field-error">@chatContextError</span>
                            }
                        </label>
                    </div>
                </section>

                <section class="settings-group">
                    <div class="settings-group-head">
                        <h3>Crawl settings</h3>
                        <p>Runtime crawl backend settings for the connected API. Leave the API key blank to keep the current secret.</p>
                    </div>

                    <div class="settings-grid">
                        <label class="settings-field settings-field-full">
                            <span class="settings-label-row">
                                <span>Endpoint</span>
                                <span class="settings-help" title="Absolute crawl API endpoint.">Crawl API URL</span>
                            </span>
                            <input class="@GetInputClass("CrawlConfig.Endpoint")"
                                   value="@_draftCrawlConfig.Endpoint"
                                   @oninput="OnCrawlEndpointChanged"
                                   disabled="@IsRuntimeSettingsDisabled"
                                   placeholder="https://api.firecrawl.dev" />
                            @if (TryGetFieldError("CrawlConfig.Endpoint", out var crawlEndpointError))
                            {
                                <span class="settings-field-error">@crawlEndpointError</span>
                            }
                        </label>

                        <div class="settings-field settings-field-full settings-inline-row">
                            <label class="settings-field">
                                <span class="settings-label-row">
                                    <span>Write-only API key</span>
                                    <span class="settings-help" title="Optional if your crawl backend does not require authentication.">Leave blank to keep current key</span>
                                </span>
                                <input class="@GetInputClass("CrawlConfig.ApiKey")"
                                       value="@_draftCrawlApiKey"
                                       @oninput="OnCrawlApiKeyChanged"
                                       type="password"
                                       disabled="@IsRuntimeSettingsDisabled"
                                       placeholder="@(_draftCrawlConfig.HasApiKey ? "Leave blank to keep current key" : "Enter crawl API key if required")" />
                                @if (TryGetFieldError("CrawlConfig.ApiKey", out var crawlApiKeyError))
                                {
                                    <span class="settings-field-error">@crawlApiKeyError</span>
                                }
                                <div class="settings-test-result" aria-live="polite">
                                    @if (HasCrawlApiTestFeedback)
                                    {
                                        <span class="@GetTestBadgeClass(_crawlApiTestStatus)"
                                              title="@_crawlApiTestMessage">
                                            @GetTestBadgeLabel(_crawlApiTestStatus)
                                        </span>
                                        <span class="@GetTestFeedbackClass(_crawlApiTestStatus)"
                                              title="@_crawlApiTestMessage">
                                            @_crawlApiTestMessage
                                        </span>
                                    }
                                </div>
                            </label>

                            <div class="settings-inline-actions">
                                <div class="settings-inline-controls">
                                    <button type="button"
                                            class="secondarybtn"
                                            @onclick="TestCrawlApiAsync"
                                            disabled="@(!CanTestCrawlApi || IsRuntimeSettingsDisabled)">
                                        @(_testingCrawlApi ? "Testing..." : "Test")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                @if (HasPendingApiConnectionChange && _runtimeSettingsLoaded)
                {
                    <p class="settings-note">
                        The runtime settings below currently reflect the active API connection.
                        Test or apply the drafted API settings to reload them for the new target.
                    </p>
                }

                @if (_loadingRuntimeSettings)
                {
                    <p class="settings-note">Loading runtime settings from the API...</p>
                }
                else if (!_runtimeSettingsLoaded)
                {
                    <p class="settings-note">
                        The runtime settings below load from the active API connection after the API request succeeds.
                    </p>
                }

                <section class="settings-group">
                    <div class="settings-group-head">
                        <h3>Search</h3>
                        <p>Controls how many results and URLs each research query processes.</p>
                    </div>

                    <div class="settings-grid">
                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Limit searches</span>
                                <span class="settings-help" title="Maximum number of search results requested for each SERP query.">Search results per query</span>
                            </span>
                            <input type="number" min="1" max="1000"
                                   class="@GetInputClass("ResearchOrchestratorConfig.LimitSearches")"
                                   @bind="_draftResearchOptions.LimitSearches"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("ResearchOrchestratorConfig.LimitSearches", out var limitSearchesError))
                            {
                                <span class="settings-field-error">@limitSearchesError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Max URL parallelism</span>
                                <span class="settings-help" title="Maximum number of source URLs processed in parallel for one SERP query.">Concurrent URL fetches</span>
                            </span>
                            <input type="number" min="1" max="1000"
                                   class="@GetInputClass("ResearchOrchestratorConfig.MaxUrlParallelism")"
                                   @bind="_draftResearchOptions.MaxUrlParallelism"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("ResearchOrchestratorConfig.MaxUrlParallelism", out var parallelismError))
                            {
                                <span class="settings-field-error">@parallelismError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Max URLs per query</span>
                                <span class="settings-help" title="Maximum number of unique URLs processed from a SERP query.">Unique URLs per query</span>
                            </span>
                            <input type="number" min="1" max="1000"
                                   class="@GetInputClass("ResearchOrchestratorConfig.MaxUrlsPerSerpQuery")"
                                   @bind="_draftResearchOptions.MaxUrlsPerSerpQuery"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("ResearchOrchestratorConfig.MaxUrlsPerSerpQuery", out var maxUrlsError))
                            {
                                <span class="settings-field-error">@maxUrlsError</span>
                            }
                        </label>

                        <label class="settings-field settings-field-full">
                            <span class="settings-label-row">
                                <span>Default discovery mode</span>
                                <span class="settings-help" title="Controls the default source-quality policy for new jobs unless the composer overrides it. Auto lets the protocol decide per query.">Source policy</span>
                            </span>
                            <select class="@GetInputClass("ResearchOrchestratorConfig.DefaultDiscoveryMode")"
                                    @bind="_draftResearchOptions.DefaultDiscoveryMode"
                                    disabled="@IsRuntimeSettingsDisabled">
                                <option value="Auto">Auto</option>
                                <option value="Balanced">Balanced</option>
                                <option value="ReliableOnly">Reliable only</option>
                                <option value="AcademicOnly">Academic only</option>
                            </select>
                            @if (TryGetFieldError("ResearchOrchestratorConfig.DefaultDiscoveryMode", out var discoveryModeError))
                            {
                                <span class="settings-field-error">@discoveryModeError</span>
                            }
                        </label>
                    </div>
                </section>

                <section class="settings-group">
                    <div class="settings-group-head">
                        <h3>Learning Similarity</h3>
                        <p>Controls filtering, grouping, and evidence capture for extracted learnings.</p>
                    </div>

                    <div class="settings-grid">
                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Min importance</span>
                                <span class="settings-help" title="Minimum importance score required when searching for similar learnings in the current job.">Similarity search floor</span>
                            </span>
                            <input type="number" min="0" max="1" step="0.01"
                                   class="@GetInputClass("LearningSimilarityOptions.MinImportance")"
                                   @bind="_draftLearningOptions.MinImportance"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("LearningSimilarityOptions.MinImportance", out var minImportanceError))
                            {
                                <span class="settings-field-error">@minImportanceError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Diversity max per URL</span>
                                <span class="settings-help" title="Maximum number of returned learnings that may come from the same source URL.">Results per source URL</span>
                            </span>
                            <input type="number" min="1" max="1000"
                                   class="@GetInputClass("LearningSimilarityOptions.DiversityMaxPerUrl")"
                                   @bind="_draftLearningOptions.DiversityMaxPerUrl"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("LearningSimilarityOptions.DiversityMaxPerUrl", out var diversityUrlError))
                            {
                                <span class="settings-field-error">@diversityUrlError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Diversity text similarity</span>
                                <span class="settings-help" title="Maximum allowed Jaccard similarity between learning texts during diversity filtering.">Text overlap ceiling</span>
                            </span>
                            <input type="number" min="0" max="1" step="0.01"
                                   class="@GetInputClass("LearningSimilarityOptions.DiversityMaxTextSimilarity")"
                                   @bind="_draftLearningOptions.DiversityMaxTextSimilarity"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("LearningSimilarityOptions.DiversityMaxTextSimilarity", out var diversityTextError))
                            {
                                <span class="settings-field-error">@diversityTextError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Max learnings per segment</span>
                                <span class="settings-help" title="Upper bound for the number of learnings extracted from a single content segment.">Extraction ceiling per segment</span>
                            </span>
                            <input type="number" min="1" max="1000"
                                   class="@GetInputClass("LearningSimilarityOptions.MaxLearningsPerSegment")"
                                   @bind="_draftLearningOptions.MaxLearningsPerSegment"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("LearningSimilarityOptions.MaxLearningsPerSegment", out var maxSegmentError))
                            {
                                <span class="settings-field-error">@maxSegmentError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Min learnings per segment</span>
                                <span class="settings-help" title="Lower bound for the number of learnings extracted from a single content segment.">Extraction floor per segment</span>
                            </span>
                            <input type="number" min="1" max="1000"
                                   class="@GetInputClass("LearningSimilarityOptions.MinLearningsPerSegment")"
                                   @bind="_draftLearningOptions.MinLearningsPerSegment"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("LearningSimilarityOptions.MinLearningsPerSegment", out var minSegmentError))
                            {
                                <span class="settings-field-error">@minSegmentError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Group assign threshold</span>
                                <span class="settings-help" title="Minimum cosine-similarity score required to auto-assign a learning to an existing group.">Auto-group similarity floor</span>
                            </span>
                            <input type="number" min="0" max="1" step="0.01"
                                   class="@GetInputClass("LearningSimilarityOptions.GroupAssignSimilarityThreshold")"
                                   @bind="_draftLearningOptions.GroupAssignSimilarityThreshold"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("LearningSimilarityOptions.GroupAssignSimilarityThreshold", out var groupThresholdError))
                            {
                                <span class="settings-field-error">@groupThresholdError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Group search top K</span>
                                <span class="settings-help" title="Number of nearest learning groups to inspect when assigning a learning to a group.">Nearest groups to inspect</span>
                            </span>
                            <input type="number" min="1" max="50"
                                   class="@GetInputClass("LearningSimilarityOptions.GroupSearchTopK")"
                                   @bind="_draftLearningOptions.GroupSearchTopK"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("LearningSimilarityOptions.GroupSearchTopK", out var groupTopKError))
                            {
                                <span class="settings-field-error">@groupTopKError</span>
                            }
                        </label>

                        <label class="settings-field">
                            <span class="settings-label-row">
                                <span>Max evidence length</span>
                                <span class="settings-help" title="Maximum number of characters stored as evidence text for a learning.">Stored evidence length</span>
                            </span>
                            <input type="number" min="1" max="1000000"
                                   class="@GetInputClass("LearningSimilarityOptions.MaxEvidenceLength")"
                                   @bind="_draftLearningOptions.MaxEvidenceLength"
                                   disabled="@IsRuntimeSettingsDisabled" />
                            @if (TryGetFieldError("LearningSimilarityOptions.MaxEvidenceLength", out var maxEvidenceError))
                            {
                                <span class="settings-field-error">@maxEvidenceError</span>
                            }
                        </label>
                    </div>
                </section>

                @if (!string.IsNullOrWhiteSpace(_settingsSuccess))
                {
                    <p class="settings-success">@_settingsSuccess</p>
                }

                @if (!string.IsNullOrWhiteSpace(_settingsError))
                {
                    <p class="settings-error">@_settingsError</p>
                }
            </div>

            <div class="settings-actions">
                <button type="button" class="secondarybtn" @onclick="CloseSettings">Close</button>
                <button type="button"
                        class="@ApplyButtonClass"
                        @onclick="SaveSettingsAsync"
                        disabled="@(!CanApplySettings)">
                    @ApplyButtonText
                </button>
            </div>
        </section>
    </div>
}
