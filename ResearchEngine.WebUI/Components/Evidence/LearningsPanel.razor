@using ResearchEngine.WebUI.Api
@using ResearchEngine.WebUI.Components.Common
@using ResearchEngine.WebUI.Services
@inject EvidenceFacade Evidence
@inject LearningGroupFacade LearningGroups
@inject OverridesStore Overrides
@inject IJSRuntime JS

<div class="panel">
    <div class="toolbar">
        <div class="left">
            <label class="sr-only" for="lrn-filter">Filter</label>
            <input id="lrn-filter"
                   class="filter"
                   placeholder="Filter learnings…"
                   value="@_filter"
                   @oninput="OnFilterInput" />
        </div>

        <button type="button" class="primary" @onclick="OpenAddDialog">Add Learning</button>
    </div>

    @if (IsOpen && HighlightLearningId is not null && !_highlightFound)
    {
        <div class="note">
            Learning not loaded yet. Load more to find it.
        </div>
    }

    @if (RestrictToGroupId is not null)
    {
        <div class="note">
            Showing learnings from the selected learning group.
        </div>
    }

    @if (_error is not null)
    {
        <ErrorBanner Error="_error" OnRetry="ReloadAsync" />
    }

    @if (_addDialogOpen)
    {
        <div class="overlay" role="presentation" @onclick="CloseAddDialog">
            <div class="dialog" role="dialog" aria-modal="true" aria-label="Add learning" @onclick:stopPropagation>
                <div class="dialog-head">
                    <strong>Add Learning</strong>
                    <button type="button" class="ghost" @onclick="CloseAddDialog" aria-label="Close">Close</button>
                </div>

                <form class="add-form" @onsubmit="AddAsync">
                    <label class="field">
                        <span>Text</span>
                        <textarea class="textarea" required @bind="_newLearningText" rows="4" placeholder="Learning text"></textarea>
                    </label>

                    <label class="field">
                        <span>Reference</span>
                        <input class="filter" @bind="_newReference" placeholder="URL or citation reference" />
                    </label>

                    <label class="field">
                        <span>Evidence text</span>
                        <textarea class="textarea" @bind="_newEvidenceText" rows="3" placeholder="Supporting notes"></textarea>
                    </label>

                    <label class="field">
                        <span>Importance score (0-1)</span>
                        <input class="filter"
                               type="number"
                               min="0"
                               max="1"
                               step="0.01"
                               @bind="_newImportanceScoreText"
                               placeholder="1.00" />
                    </label>

                    <label class="field">
                        <span>Language</span>
                        <input class="filter" @bind="_newLanguage" placeholder="en" />
                    </label>

                    <label class="field">
                        <span>Region</span>
                        <input class="filter" @bind="_newRegion" placeholder="US, Europe..." />
                    </label>

                    <div class="dialog-actions">
                        <button type="submit" class="primary" disabled="@_addBusy">
                            @(_addBusy ? "Adding..." : "Add")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }

    <ul class="list" role="list">
        @foreach (var item in Filtered())
        {
            var isHighlight = HighlightLearningId is not null && item.LearningId == HighlightLearningId.Value;

            var pinned = Overrides.IsPinnedLearning(JobId, item.LearningId);
            var excluded = Overrides.IsExcludedLearning(JobId, item.LearningId);

            <li id="@GetRowId(item.LearningId)"
                class="row @(isHighlight ? "hl" : "")"
                tabindex="0">

                <div class="text">@item.Text</div>
                <div class="meta">
                    <span>@item.ImportanceScore.ToString("0.00")</span>
                    <span class="dot">•</span>
                    <span class="src">@item.SourceReference</span>
                    <span class="dot">•</span>
                    <span>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                </div>

                <div class="actions">
                    <button type="button"
                            class="ghost"
                            disabled="@(!CanOpenExternalUrl(item.SourceReference))"
                            @onclick="() => OpenExternalAsync(item.SourceReference)">
                        Open
                    </button>

                    <button type="button"
                            class="toggle @(pinned ? "active" : "")"
                            @onclick="() => TogglePinned(item.LearningId)"
                            aria-pressed="@pinned">
                        Pin
                    </button>

                    <button type="button"
                            class="toggle @(excluded ? "active" : "")"
                            @onclick="() => ToggleExcluded(item.LearningId)"
                            aria-pressed="@excluded">
                        Exclude
                    </button>

                    <button type="button" class="ghost" @onclick="() => DeleteAsync(item.LearningId)">Delete</button>
                </div>
            </li>
        }
    </ul>

    <div class="foot">
        <button type="button" class="secondary" @onclick="LoadMoreAsync" disabled="@(!_canLoadMore || _busy)">
            @(_busy ? "Loading…" : "Load more")
        </button>
    </div>
</div>

@code {
    [Parameter] public Guid JobId { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? HighlightLearningId { get; set; }
    [Parameter] public string? FocusSourceReference { get; set; }
    [Parameter] public Guid? RestrictToGroupId { get; set; }

    [Parameter] public string FilterText { get; set; } = "";
    [Parameter] public EventCallback<string> FilterTextChanged { get; set; }

    [Parameter] public int InitialLoadedCount { get; set; } = 25;
    [Parameter] public EventCallback<int> LoadedCountChanged { get; set; }

    private readonly List<LearningListItemDto> _items = new();
    private readonly HashSet<Guid> _loadedIds = new();
    private int _skip = 0;
    private const int Take = 25;
    private const int FocusTake = 200;

    private bool _busy;
    private bool _canLoadMore = true;

    private string _filter = "";
    private bool _addBusy;
    private bool _addDialogOpen;
    private string _newLearningText = "";
    private string? _newReference;
    private string? _newEvidenceText;
    private string? _newImportanceScoreText;
    private string? _newLanguage;
    private string? _newRegion;
    private ApiError? _error;

    private bool _highlightFound;
    private bool _restoredToTarget;
    private string _activeLoadKey = string.Empty;

    private readonly Dictionary<Guid, Guid?> _groupByLearningId = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen)
            return;

        var incoming = FilterText ?? "";

        if (_filter != incoming)
            _filter = incoming;

        var isFocusedOpenMode = IsFocusedOpenMode();
        var loadKey = BuildLoadKey();
        var shouldReload = _items.Count == 0;

        if (!shouldReload && !string.Equals(_activeLoadKey, loadKey, StringComparison.Ordinal))
        {
            // Reload only when entering/changing focused mode.
            // Leaving focused mode (e.g. after "Load more" clears filter) should keep current items.
            shouldReload = isFocusedOpenMode;
        }

        if (shouldReload)
        {
            _activeLoadKey = loadKey;
            await ReloadAsync();
        }
        else
        {
            _activeLoadKey = loadKey;
        }

        if (!_restoredToTarget && !IsFocusedOpenMode())
            await EnsureLoadedToTargetAsync();

        if (RestrictToGroupId is not null)
            await ResolveGroupsForItemsAsync(_items.Select(x => x.LearningId));

        await EnsureFilterHasVisibleResultsAsync();

        await TryApplyHighlightAsync();
    }

    private async Task ReloadAsync()
    {
        _error = null;
        _items.Clear();
        _loadedIds.Clear();
        _skip = 0;
        _canLoadMore = true;
        _highlightFound = false;
        _restoredToTarget = false;
        _groupByLearningId.Clear();

        await NotifyLoadedCountAsync();

        if (IsFocusedOpenMode())
        {
            await LoadFocusedReferenceAsync();
            _restoredToTarget = true;
            return;
        }

        await LoadMoreAsync();
    }

    private async Task EnsureLoadedToTargetAsync()
    {
        // best-effort restore: load pages until we reach InitialLoadedCount or there is no more
        var target = Math.Max(Take, InitialLoadedCount);
        if (_items.Count >= target)
        {
            _restoredToTarget = true;
            return;
        }

        // Avoid infinite loops on errors
        var safety = 10; // at most 10 additional pages
        while (_items.Count < target && _canLoadMore && safety-- > 0)
        {
            await LoadMoreAsync();
            if (_error is not null) break;
        }

        _restoredToTarget = true;
    }

    private async Task OnFilterInput(ChangeEventArgs e)
    {
        _filter = e.Value?.ToString() ?? "";
        if (FilterTextChanged.HasDelegate)
            await FilterTextChanged.InvokeAsync(_filter);
    }

    private async Task LoadMoreAsync()
    {
        if (_busy || !_canLoadMore) return;

        if (IsFocusedOpenMode() && !string.IsNullOrWhiteSpace(_filter))
            await ResetFilterForLoadMoreAsync();

        _busy = true;
        _error = null;

        var promoteLearningId = IsFocusedOpenMode() ? HighlightLearningId : null;
        var res = await Evidence.GetLearningsAsync(
            JobId,
            _skip,
            Take,
            sourceReference: null,
            promoteLearningId: promoteLearningId);
        if (!res.IsSuccess)
        {
            _error = res.Error;
            _busy = false;
            return;
        }

        var page = res.Data ?? Array.Empty<LearningListItemDto>();
        AppendUnique(page);
        await ResolveGroupsForItemsAsync(page.Select(x => x.LearningId));
        PromoteHighlightedToTop();

        _skip += page.Count;
        _canLoadMore = page.Count == Take;

        _busy = false;

        await NotifyLoadedCountAsync();
        await TryApplyHighlightAsync();
    }

    private async ValueTask NotifyLoadedCountAsync()
    {
        if (LoadedCountChanged.HasDelegate)
            await LoadedCountChanged.InvokeAsync(_items.Count);
    }

    private async Task AddAsync()
    {
        if (_addBusy) return;

        var text = (_newLearningText ?? "").Trim();
        if (string.IsNullOrWhiteSpace(text)) return;

        float? importanceScore = null;
        if (!string.IsNullOrWhiteSpace(_newImportanceScoreText))
        {
            if (!float.TryParse(_newImportanceScoreText, out var parsed) || parsed < 0f || parsed > 1f)
            {
                _error = new ApiError(ApiErrorKind.Validation, "Importance score must be a number between 0 and 1.");
                return;
            }

            importanceScore = parsed;
        }

        _addBusy = true;
        _error = null;

        var req = new AddLearningRequest
        {
            Text = text,
            Reference = NormalizeNullable(_newReference),
            EvidenceText = NormalizeNullable(_newEvidenceText),
            ImportanceScore = importanceScore,
            Language = NormalizeNullable(_newLanguage),
            Region = NormalizeNullable(_newRegion)
        };

        var res = await Evidence.AddLearningAsync(JobId, req);
        if (!res.IsSuccess)
        {
            _error = res.Error;
            _addBusy = false;
            return;
        }

        var added = res.Data!;
        if (_loadedIds.Add(added.LearningId))
            _items.Insert(0, added);
        else
            PromoteHighlightedToTop();

        await ResolveGroupsForItemsAsync(new[] { added.LearningId });

        ResetAddForm();
        _addDialogOpen = false;
        _addBusy = false;

        PromoteHighlightedToTop();
        await NotifyLoadedCountAsync();
        await TryApplyHighlightAsync();
    }

    private async Task ResetFilterForLoadMoreAsync()
    {
        _filter = string.Empty;
        if (FilterTextChanged.HasDelegate)
            await FilterTextChanged.InvokeAsync(_filter);
    }

    private async Task DeleteAsync(Guid learningId)
    {
        var ok = false;
        try { ok = await JS.InvokeAsync<bool>("confirm", "Delete this learning?"); } catch { }
        if (!ok) return;

        _error = null;

        var idx = _items.FindIndex(x => x.LearningId == learningId);
        if (idx < 0) return;

        var removed = _items[idx];
        var hadGroup = _groupByLearningId.TryGetValue(learningId, out var removedGroupId);
        _items.RemoveAt(idx);
        _loadedIds.Remove(learningId);
        _groupByLearningId.Remove(learningId);

        var res = await Evidence.DeleteLearningAsync(JobId, learningId);
        if (!res.IsSuccess)
        {
            _items.Insert(idx, removed);
            _loadedIds.Add(removed.LearningId);
            if (hadGroup)
                _groupByLearningId[removed.LearningId] = removedGroupId;
            _error = res.Error;
            return;
        }

        await NotifyLoadedCountAsync();
    }

    private void TogglePinned(Guid learningId)
    {
        Overrides.TogglePinnedLearning(JobId, learningId);
        StateHasChanged();
    }

    private void ToggleExcluded(Guid learningId)
    {
        Overrides.ToggleExcludedLearning(JobId, learningId);
        StateHasChanged();
    }

    private async Task OpenExternalAsync(string? rawReference)
    {
        var url = BuildExternalUrl(rawReference);
        if (url is null) return;

        try { await JS.InvokeVoidAsync("open", url, "_blank", "noopener,noreferrer"); } catch { }
    }

    private static bool CanOpenExternalUrl(string? rawReference)
        => BuildExternalUrl(rawReference) is not null;

    private static string? BuildExternalUrl(string? rawReference)
    {
        var raw = rawReference?.Trim();
        if (string.IsNullOrWhiteSpace(raw))
            return null;

        if (Uri.TryCreate(raw, UriKind.Absolute, out var absolute) &&
            (absolute.Scheme == Uri.UriSchemeHttp || absolute.Scheme == Uri.UriSchemeHttps))
        {
            return absolute.ToString();
        }

        if (Uri.TryCreate($"https://{raw}", UriKind.Absolute, out var withScheme) &&
            (withScheme.Scheme == Uri.UriSchemeHttp || withScheme.Scheme == Uri.UriSchemeHttps))
        {
            return withScheme.ToString();
        }

        return null;
    }

    private void OpenAddDialog()
    {
        _error = null;
        _addDialogOpen = true;
    }

    private void CloseAddDialog()
    {
        if (_addBusy) return;
        _addDialogOpen = false;
    }

    private void ResetAddForm()
    {
        _newLearningText = "";
        _newReference = null;
        _newEvidenceText = null;
        _newImportanceScoreText = null;
        _newLanguage = null;
        _newRegion = null;
    }

    private static string? NormalizeNullable(string? value)
    {
        var v = value?.Trim();
        return string.IsNullOrWhiteSpace(v) ? null : v;
    }

    private bool IsFocusedOpenMode()
        => NormalizeNullable(FocusSourceReference) is not null;

    private string BuildLoadKey()
    {
        var normalizedSourceReference = NormalizeNullable(FocusSourceReference);
        var promoted = normalizedSourceReference is null
            ? null
            : HighlightLearningId?.ToString("N");

        return $"{JobId:N}|{normalizedSourceReference ?? string.Empty}|{promoted ?? string.Empty}";
    }

    private async Task LoadFocusedReferenceAsync()
    {
        var sourceReference = NormalizeNullable(FocusSourceReference);
        if (sourceReference is null)
            return;

        _busy = true;
        _error = null;

        try
        {
            var focusSkip = 0;
            var safety = 25; // Cap worst-case network churn if reference has many pages.

            while (safety-- > 0)
            {
                var res = await Evidence.GetLearningsAsync(
                    JobId,
                    focusSkip,
                    FocusTake,
                    sourceReference: sourceReference,
                    promoteLearningId: HighlightLearningId);

                if (!res.IsSuccess)
                {
                    _error = res.Error;
                    break;
                }

                var page = res.Data ?? Array.Empty<LearningListItemDto>();
                AppendUnique(page);
                await ResolveGroupsForItemsAsync(page.Select(x => x.LearningId));

                focusSkip += page.Count;
                if (page.Count < FocusTake)
                    break;
            }
        }
        finally
        {
            _busy = false;
        }

        PromoteHighlightedToTop();
        _skip = 0; // In focused mode, "Load more" starts global paging from the beginning.
        _canLoadMore = true;

        await NotifyLoadedCountAsync();
        await TryApplyHighlightAsync();
    }

    private void AppendUnique(IEnumerable<LearningListItemDto> page)
    {
        foreach (var item in page)
        {
            if (_loadedIds.Add(item.LearningId))
                _items.Add(item);
        }
    }

    private void PromoteHighlightedToTop()
    {
        if (HighlightLearningId is null || _items.Count < 2)
            return;

        var highlightId = HighlightLearningId.Value;
        var index = _items.FindIndex(x => x.LearningId == highlightId);
        if (index <= 0)
            return;

        var highlighted = _items[index];
        _items.RemoveAt(index);
        _items.Insert(0, highlighted);
    }

    private async Task ResolveGroupsForItemsAsync(IEnumerable<Guid> learningIds)
    {
        var ids = learningIds
            .Where(id => id != Guid.Empty)
            .Distinct()
            .Where(id => !_groupByLearningId.ContainsKey(id))
            .ToList();

        if (ids.Count == 0)
            return;

        var prefetchErr = await LearningGroups.PrefetchGroupsAsync(ids);
        if (prefetchErr is not null)
            return;

        foreach (var id in ids)
        {
            if (LearningGroups.TryGetCached(id, out var group))
                _groupByLearningId[id] = group?.GroupId;
            else
                _groupByLearningId[id] = null;
        }
    }

    private async Task EnsureFilterHasVisibleResultsAsync()
    {
        if (string.IsNullOrWhiteSpace(_filter))
            return;

        if (Filtered().Any())
            return;

        if (!_canLoadMore)
            return;

        var safety = 20;
        while (_canLoadMore && !Filtered().Any() && safety-- > 0)
        {
            await LoadMoreAsync();
            if (_error is not null)
                break;
        }
    }

    private IEnumerable<LearningListItemDto> Filtered()
    {
        var f = (_filter ?? "").Trim();
        var query = _items.AsEnumerable();

        if (RestrictToGroupId is not null)
        {
            var groupId = RestrictToGroupId.Value;
            query = query.Where(x =>
                _groupByLearningId.TryGetValue(x.LearningId, out var gid) &&
                gid is not null &&
                gid.Value == groupId);
        }

        if (string.IsNullOrWhiteSpace(f))
            return query;

        return query.Where(x =>
            (x.Text?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (x.SourceReference?.Contains(f, StringComparison.OrdinalIgnoreCase) ?? false));
    }

    private async Task TryApplyHighlightAsync()
    {
        _highlightFound = false;

        if (!IsOpen || HighlightLearningId is null) return;

        var id = HighlightLearningId.Value;
        if (Filtered().Any(x => x.LearningId == id))
        {
            _highlightFound = true;

            try
            {
                await JS.InvokeVoidAsync("researchEngine.citations.scrollIntoViewById", GetRowId(id));
            }
            catch { }
        }
    }

    private static string GetRowId(Guid id) => $"learning-{id:N}";

}
