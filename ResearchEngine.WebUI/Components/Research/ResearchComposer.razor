@using ResearchEngine.WebUI.Components.Common
@using ResearchEngine.WebUI.Services
@using ResearchEngine.WebUI.Api
@inject ResearchProtocolFacade Protocol
@inject JobCreationFacade Jobs
@inject IResearchApiClient Api
@inject NavigationManager Nav

<div class="composer-wrap" aria-label="New research composer">
    <div class="composer">
        <div class="head">
            <div class="title">New Research</div>
            <div class="hint">Ask anything. Tune breadth/depth if you want.</div>
        </div>

        <div class="box">
            @if (_error is not null)
            {
                <ErrorBanner Error="_error" OnRetry="RetryAsync" />
            }

            @if (_state == ComposerState.AnsweringClarifications)
            {
                <div class="clarifications">
                    <div class="clar-title">Clarifying questions</div>
                    <div class="clar-sub">
                        You can leave answers empty — only answered ones will be sent.
                    </div>

                    <div class="clar-list">
                        @for (var i = 0; i < _questions.Count; i++)
                        {
                            var q = _questions[i];
                            _answers.TryGetValue(q, out var a);

                            <div class="clar-item">
                                <div class="clar-q">@q</div>
                                <input class="input"
                                       placeholder="Your answer (optional)…"
                                       value="@a"
                                       @oninput="e => SetAnswer(q, e.Value?.ToString() ?? string.Empty)" />
                            </div>
                        }
                    </div>

                    <div class="clar-actions">
                        <button type="button" class="secondarybtn" @onclick="BackToEdit">
                            Back
                        </button>

                        <div class="spacer"></div>

                        <button type="button" class="runbtn"
                                @onclick="RunAsync"
                                disabled="@(_busy)">
                            @(_busy ? _busyText : "Run research")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <textarea id="queryBox"
                          class="query"
                          rows="6"
                          placeholder="Ask anything…"
                          aria-describedby="queryTip"
                          @bind-value="_query"
                          @bind-value:event="oninput"
                          @onkeydown="OnQueryKeyDown"></textarea>

                <div id="queryTip" class="tip">Tip: Press Ctrl+Enter to run.</div>

                <div class="settings-bar">
                    <button type="button" class="settings"
                            @onclick="ToggleSettings">
                        @(_showSettings ? "Hide settings" : "Settings")
                    </button>

                    <div class="spacer"></div>

                    <button type="button"
                            class="runbtn"
                            @onclick="RunAsync"
                            disabled="@(!CanRun || _busy)">
                        @(_busy ? _busyText : "Run research")
                    </button>
                </div>

                @if (_showSettings)
                {
                    <div class="settings-grid" role="group" aria-label="Research settings">
                        <div class="field field-compact">
                            <div class="lbl lbl-help"
                                 tabindex="0">
                                Breadth
                                <span id="breadthHelp" role="tooltip" class="field-help-tip">
                                    Breadth controls how many different search paths the research explores. Higher values cast a wider net, but usually take longer and may pull in more marginal sources.
                                </span>
                            </div>
                            <select class="input"
                                    aria-describedby="breadthHelp"
                                    value="@(_breadth?.ToString() ?? string.Empty)"
                                    @onchange="e => SetBreadth(e.Value?.ToString())">
                                <option value="">Auto</option>
                                @foreach (var value in BreadthOptions)
                                {
                                    <option value="@value">@value</option>
                                }
                            </select>
                        </div>

                        <div class="field field-compact">
                            <div class="lbl lbl-help"
                                 tabindex="0">
                                Depth
                                <span id="depthHelp" role="tooltip" class="field-help-tip">
                                    Depth controls how far the research follows leads and refines findings. Higher values do more iterative digging and cross-checking.
                                </span>
                            </div>
                            <select class="input"
                                    aria-describedby="depthHelp"
                                    value="@(_depth?.ToString() ?? string.Empty)"
                                    @onchange="e => SetDepth(e.Value?.ToString())">
                                <option value="">Auto</option>
                                @foreach (var value in DepthOptions)
                                {
                                    <option value="@value">@value</option>
                                }
                            </select>
                        </div>

                        <div class="field field-mode">
                            <div class="lbl lbl-help"
                                 tabindex="0">
                                Sources
                                <span id="discoveryModeHelp" role="tooltip" class="field-help-tip">
                                    Balanced mixes source types. Reliable only favors higher-trust sources like official statements and established publications. Academic only focuses on papers, journals, and preprints.
                                </span>
                            </div>
                            <select class="input"
                                    aria-label="Discovery mode"
                                    aria-describedby="discoveryModeHelp"
                                    value="@_discoveryModeOverride"
                                    @onchange="e => _discoveryModeOverride = NormalizeDiscoveryMode(e.Value?.ToString())">
                                <option value="Balanced">Balanced</option>
                                <option value="ReliableOnly">Reliable only</option>
                                <option value="AcademicOnly">Academic only</option>
                            </select>
                        </div>

                        <div class="field field-region">
                            <div class="lbl lbl-help"
                                 tabindex="0">
                                Region
                                <span id="regionHelp" role="tooltip" class="field-help-tip">
                                    Region biases search and source discovery toward a country or geographic area when local context matters. Leave it empty for a broader global search.
                                </span>
                            </div>
                            <input class="input"
                                   aria-describedby="regionHelp"
                                   placeholder="Russia, Bavaria (Germany)…"
                                   value="@(_region ?? string.Empty)"
                                   @oninput="e => _region = e.Value?.ToString()" />
                        </div>

                        <div class="field field-toggle">
                            <div class="lbl">Clarifications</div>
                            <label class="check">
                                <input type="checkbox" @bind="_askClarifications" />
                                Ask clarifying questions
                            </label>
                        </div>
                    </div>
                }

                @if (_paramsWarning is not null)
                {
                    <div class="warning">@_paramsWarning</div>
                }
            }
        </div>
    </div>
</div>

@code
{
    [Parameter] public EventCallback<Guid> OnJobCreated { get; set; }

    private enum ComposerState
    {
        Editing,
        AnsweringClarifications
    }

    private ComposerState _state = ComposerState.Editing;

    private string _query = string.Empty;
    private bool _askClarifications = false;
    private bool _showSettings = false;

    private int? _breadth;
    private int? _depth;
    private string? _region;
    private string _discoveryModeOverride = "Balanced";

    private bool _busy;
    private string _busyText = "Working…";

    private ApiError? _error;
    private string? _paramsWarning;

    private readonly List<string> _questions = new();
    private readonly Dictionary<string, string> _answers = new();
    private static readonly int[] BreadthOptions = { 1, 2, 3, 4, 5, 6, 7, 8 };
    private static readonly int[] DepthOptions = { 1, 2, 3, 4 };

    private bool CanRun => !string.IsNullOrWhiteSpace(_query);

    protected override async Task OnInitializedAsync()
    {
        _discoveryModeOverride = await LoadDefaultDiscoveryModeAsync();
    }

    private void ToggleSettings() => _showSettings = !_showSettings;

    private void BackToEdit()
    {
        _error = null;
        _state = ComposerState.Editing;
    }

    private void SetAnswer(string question, string answer)
    {
        _answers[question] = answer;
    }

    private void SetBreadth(string? raw)
    {
        _breadth = TryParseNullableInt(raw);
    }

    private void SetDepth(string? raw)
    {
        _depth = TryParseNullableInt(raw);
    }

    private static int? TryParseNullableInt(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
            return null;

        return int.TryParse(raw, out var v) ? v : null;
    }

    private async Task RetryAsync() => await RunAsync();

    private async Task RunAsync()
    {
        if (!CanRun || _busy)
            return;

        _error = null;
        _paramsWarning = null;

        var query = _query.Trim();

        try
        {
            _busy = true;

            // 1) Clarifications (optional)
            if (_askClarifications && _state != ComposerState.AnsweringClarifications)
            {
                _busyText = "Generating clarifying questions…";

                var qRes = await Protocol.GetClarificationQuestionsAsync(
                    query: query,
                    ct: CancellationToken.None);

                if (!qRes.IsSuccess)
                {
                    _error = qRes.Error;
                    return;
                }

                _questions.Clear();
                _answers.Clear();
                _questions.AddRange(qRes.Data ?? Array.Empty<string>());

                if (_questions.Count > 0)
                {
                    _state = ComposerState.AnsweringClarifications;
                    return;
                }
            }

            // 2) Parameters (recommended defaults + allow overrides)
            _busyText = "Selecting parameters…";

            var answeredClarifications = GetAnsweredClarifications();

            Dictionary<string, object>? overrides = null;
            // Only send overrides if user provided something (optional)
            if (_breadth is not null || _depth is not null || !string.IsNullOrWhiteSpace(_region))
            {
                overrides = new Dictionary<string, object>();
                if (_breadth is not null) overrides["breadth"] = _breadth.Value;
                if (_depth is not null) overrides["depth"] = _depth.Value;
                if (!string.IsNullOrWhiteSpace(_region)) overrides["region"] = _region!.Trim();
            }

            var pRes = await Protocol.GetParametersAsync(
                query: query,
                clarifications: answeredClarifications,
                overrides: overrides,
                ct: CancellationToken.None);

            int breadth = 2, depth = 2;
            string language = "en";
            string? region = null;

            if (pRes.IsSuccess)
            {
                (breadth, depth, language, region) = pRes.Data;

                // Populate only if user hasn't typed values yet
                _breadth ??= breadth;
                _depth ??= depth;
                _region ??= region;
            }
            else
            {
                _paramsWarning = "Could not load recommended parameters. Using safe defaults (breadth=2, depth=2, language=en).";
            }

            breadth = _breadth ?? breadth;
            depth = _depth ?? depth;
            language = NormalizeLanguageCode(language) ?? "en";
            region = NormalizeRegion(_region);

            // 3) Create job
            _busyText = "Creating job…";

            var createRes = await Jobs.CreateJobAsync(
                query: query,
                clarifications: answeredClarifications,
                breadth: breadth,
                depth: depth,
                language: language,
                discoveryMode: _discoveryModeOverride,
                region: region,
                ct: CancellationToken.None);

            if (!createRes.IsSuccess || createRes.Data == Guid.Empty)
            {
                _error = createRes.Error ?? new ApiError(ApiErrorKind.Unexpected, "Job creation failed.");
                return;
            }

            var jobId = createRes.Data;

            // notify parent (optional) + navigate
            if (OnJobCreated.HasDelegate)
                await OnJobCreated.InvokeAsync(jobId);

            Nav.NavigateTo($"/jobs/{jobId}");
        }
        catch (Exception ex)
        {
            _error = ApiErrorMapper.Map(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private IReadOnlyList<(string question, string answer)> GetAnsweredClarifications()
    {
        if (_questions.Count == 0)
            return Array.Empty<(string, string)>();

        var list = new List<(string, string)>();
        foreach (var q in _questions)
        {
            if (_answers.TryGetValue(q, out var a) && !string.IsNullOrWhiteSpace(a))
                list.Add((q, a.Trim()));
        }
        return list;
    }

    private static string? NormalizeLanguageCode(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
            return null;

        var s = raw.Trim().ToLowerInvariant();
        return s.Length == 2 ? s : null;
    }

    private static string? NormalizeRegion(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
            return null;

        var s = raw.Trim();
        return s.Length == 0 ? null : s;
    }

    private static string NormalizeDiscoveryMode(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
            return "Balanced";

        return raw.Trim() switch
        {
            "Balanced" => "Balanced",
            "ReliableOnly" => "ReliableOnly",
            "AcademicOnly" => "AcademicOnly",
            _ => "Balanced"
        };
    }

    private async Task<string> LoadDefaultDiscoveryModeAsync()
    {
        try
        {
            var runtime = await Api.RuntimeGETAsync(CancellationToken.None);
            return NormalizeDiscoveryMode(runtime?.ResearchOrchestratorConfig?.DefaultDiscoveryMode);
        }
        catch
        {
            return "Balanced";
        }
    }

    private async Task OnQueryKeyDown(KeyboardEventArgs e)
    {
        if (e.CtrlKey && e.Key == "Enter")
            await RunAsync();
    }
}
