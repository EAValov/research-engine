@using ResearchEngine.WebUI.Api
@using ResearchEngine.WebUI.Components.Common
@using ResearchEngine.WebUI.Services

@if (Error is not null)
{
    <ErrorBanner Error="Error" />
}

<div class="cmp">
    <div class="cmp-head">
        <div class="side">
            <label class="lbl">A</label>
            <input class="idbox" value="@AIdText" placeholder="Pick A from history…" readonly />
            @if (!string.IsNullOrWhiteSpace(AStatus))
            {
                <span class="pill">@AStatus</span>
            }
        </div>

        <button type="button" class="swap" @onclick="OnSwap" disabled="@(!CanSwap)" aria-label="Swap A and B">
            Swap
        </button>

        <div class="side">
            <label class="lbl">B</label>
            <input class="idbox" value="@BIdText" placeholder="Pick B from history…" readonly />
            @if (!string.IsNullOrWhiteSpace(BStatus))
            {
                <span class="pill">@BStatus</span>
            }
        </div>
    </div>

    <div class="cmp-body">
        <div class="col" aria-label="Synthesis A">
            @if (AId is null)
            {
                <p class="muted">Select synthesis A.</p>
            }
            else if (string.IsNullOrWhiteSpace(AMarkdown))
            {
                <p class="muted">No content.</p>
            }
            else
            {
                <MarkdownView Markdown="@AMarkdown" />
            }
        </div>

        <div class="col" aria-label="Synthesis B">
            @if (BId is null)
            {
                <p class="muted">Select synthesis B.</p>
            }
            else if (string.IsNullOrWhiteSpace(BMarkdown))
            {
                <p class="muted">No content.</p>
            }
            else
            {
                <MarkdownView Markdown="@BMarkdown" />
            }
        </div>
    </div>

    <div class="hint muted">
        Tip: use the A/B buttons in History to populate compare quickly.
    </div>
</div>

@code {
    [Parameter] public Guid JobId { get; set; }

    [Parameter] public Guid? AId { get; set; }
    [Parameter] public Guid? BId { get; set; }

    [Parameter] public string? AStatus { get; set; }
    [Parameter] public string? BStatus { get; set; }

    [Parameter] public string AMarkdown { get; set; } = "";
    [Parameter] public string BMarkdown { get; set; } = "";

    [Parameter] public ApiError? Error { get; set; }

    [Parameter] public EventCallback OnSwap { get; set; }
    [Parameter] public EventCallback<Guid> OnPickA { get; set; }
    [Parameter] public EventCallback<Guid> OnPickB { get; set; }

    private bool CanSwap => AId is not null && BId is not null;

    private string AIdText => AId is null ? "" : AId.Value.ToString();
    private string BIdText => BId is null ? "" : BId.Value.ToString();
}