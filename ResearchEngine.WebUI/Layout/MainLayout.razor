@inherits LayoutComponentBase
@implements IAsyncDisposable
@using ResearchEngine.WebUI.State
@using ResearchEngine.WebUI.Services
@inject AppStateStore AppState
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject LocalStorageService LocalStorage
@inject UpdateStatusService UpdateStatus
@inject AppRuntimeInfo RuntimeInfo

<div class="app" data-theme="@_applied">
    <header class="header">
        <div class="header-left">
            <a class="brand" href="/" aria-label="Go to job list">Research Engine</a>
            <div class="api-health" aria-label="API health indicators">
                <span class="@GetIndicatorClass(_liveStatus)" title="@GetIndicatorTitle("Live", _liveStatus)">Live</span>
                <span class="@GetIndicatorClass(_readyStatus)" title="@GetIndicatorTitle("Ready", _readyStatus)">Ready</span>
                @if (ShouldShowUpdateNotice && _updateStatus is not null)
                {
                    <span class="update-notice" role="status" aria-live="polite">
                        @if (HasUpdateLink)
                        {
                            <a class="update-badge"
                               href="@_updateStatus.ReleaseUrl"
                               target="_blank"
                               rel="noreferrer"
                               title="@GetUpdateNoticeTitle(_updateStatus)">
                                Update v@_updateStatus.LatestVersion
                            </a>
                        }
                        else
                        {
                            <span class="update-badge" title="@GetUpdateNoticeTitle(_updateStatus)">
                                Update v@_updateStatus.LatestVersion
                            </span>
                        }

                        <button type="button"
                                class="update-dismiss"
                                @onclick="DismissUpdateNoticeAsync"
                                aria-label="Dismiss update notification"
                                title="Dismiss this update notification until a newer version is released.">
                            ×
                        </button>
                    </span>
                }
            </div>
        </div>

        <div class="header-right">
            <SettingsDialog />

            <button type="button"
                    class="archive-toggle"
                    @onclick="ToggleArchiveView"
                    aria-label="@ArchiveToggleAriaLabel"
                    title="@ArchiveToggleAriaLabel">
                @ArchiveToggleLabel
            </button>

            <button type="button"
                    class="theme-toggle"
                    @onclick="ToggleThemeAsync"
                    aria-label="@ThemeAriaLabel"
                    title="@ThemeAriaLabel">
                <span class="theme-icon" aria-hidden="true">@ThemeGlyph</span>
                <span class="theme-text">@ThemeLabel</span>
            </button>
        </div>
    </header>

    <main class="main" id="mainContent">
        @Body
    </main>
</div>

@code {
    private enum ApiProbeStatus
    {
        Unknown,
        Healthy,
        Unhealthy,
        Unreachable
    }

    private readonly record struct ProbeResult(ApiProbeStatus Status, int? StatusCode = null);
    private const string DismissedUpdateVersionStorageKey = "researchEngine:updateNotice:dismissedVersion";

    // Stored preference: "light" | "dark" | (null/empty/"system") => follow system
    private string _applied = string.Empty; // actual applied (light|dark)

    private ApiProbeStatus _liveStatus = ApiProbeStatus.Unknown;
    private ApiProbeStatus _readyStatus = ApiProbeStatus.Unknown;
    private CancellationTokenSource? _healthPollCts;
    private Task? _healthPollTask;
    private Task? _updatePollTask;
    private string _currentLocation = string.Empty;
    private UpdateStatusResult? _updateStatus;
    private string? _dismissedUpdateVersion;

    private string ThemeLabel => _applied == "dark" ? "Dark" : "Light";
    private string ThemeGlyph => _applied == "dark" ? "🌙" : "☀️";

    private string ThemeAriaLabel => _applied == "dark"
        ? "Theme: dark. Click to switch to light."
        : "Theme: light. Click to switch to dark.";

    private bool IsArchiveRoute => IsArchivePath(_currentLocation);

    private string ArchiveToggleLabel => IsArchiveRoute ? "Recent jobs" : "Archived jobs";
    private string ArchiveToggleAriaLabel => IsArchiveRoute
        ? "Open recent jobs"
        : "Open archived jobs";
    private bool HasUpdateLink => !string.IsNullOrWhiteSpace(_updateStatus?.ReleaseUrl);
    private bool ShouldShowUpdateNotice
        => _updateStatus is { CheckEnabled: true, UpdateAvailable: true, LatestVersion: { Length: > 0 } latestVersion }
           && !string.Equals(
               NormalizeVersion(latestVersion),
               NormalizeVersion(_dismissedUpdateVersion),
               StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        _currentLocation = Nav.Uri;
        Nav.LocationChanged += OnLocationChanged;

        _healthPollCts = new CancellationTokenSource();
        _healthPollTask = PollApiHealthLoopAsync(_healthPollCts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var pref = AppState.GetTheme();
        try
        {
            if (pref is "dark" or "light")
            {
                _applied = await JS.InvokeAsync<string>("researchEngine.theme.set", pref);
            }
            else
            {
                // default: system theme (but not a user-selectable option)
                _applied = await JS.InvokeAsync<string>("researchEngine.theme.init");
            }
        }
        catch
        {
            _applied = (pref == "dark") ? "dark" : "light";
        }

        if (RuntimeInfo.IsStableRelease && _healthPollCts is not null)
        {
            _updatePollTask = PollUpdateLoopAsync(_healthPollCts.Token);
        }

        StateHasChanged();
    }

    private async Task ToggleThemeAsync()
    {
        var next = _applied == "dark" ? "light" : "dark";

        AppState.SetTheme(next);

        try
        {
            _applied = await JS.InvokeAsync<string>("researchEngine.theme.set", next);
        }
        catch
        {
            _applied = next;
        }
    }

    private void ToggleArchiveView()
    {
        if (IsArchiveRoute)
        {
            Nav.NavigateTo("/");
            return;
        }

        Nav.NavigateTo("/archive");
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentLocation = e.Location;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task PollApiHealthLoopAsync(CancellationToken ct)
    {
        try
        {
            await RefreshApiHealthAsync(ct);

            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            while (await timer.WaitForNextTickAsync(ct))
                await RefreshApiHealthAsync(ct);
        }
        catch (OperationCanceledException)
        {
            // expected on layout disposal
        }
    }

    private async Task RefreshApiHealthAsync(CancellationToken ct)
    {
        var liveTask = ProbeCurrentApiEndpointAsync("/health/live", ct);
        var readyTask = ProbeCurrentApiEndpointAsync("/health/ready", ct);

        await Task.WhenAll(liveTask, readyTask);

        var live = await liveTask;
        var ready = await readyTask;

        await InvokeAsync(() =>
        {
            _liveStatus = live.Status;
            _readyStatus = ready.Status;
            StateHasChanged();
        });
    }

    private async Task PollUpdateLoopAsync(CancellationToken ct)
    {
        try
        {
            _dismissedUpdateVersion = NormalizeVersion(await LocalStorage.GetAsync(DismissedUpdateVersionStorageKey));

            if (!await RefreshUpdateStatusAsync(ct))
                return;

            using var timer = new PeriodicTimer(TimeSpan.FromHours(6));
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (!await RefreshUpdateStatusAsync(ct))
                    return;
            }
        }
        catch (OperationCanceledException)
        {
            // expected on layout disposal
        }
    }

    private async Task<bool> RefreshUpdateStatusAsync(CancellationToken ct)
    {
        var status = await UpdateStatus.GetStatusAsync(ct);
        if (status is null)
            return true;

        await InvokeAsync(() =>
        {
            _updateStatus = status;
            StateHasChanged();
        });

        return status.CheckEnabled;
    }

    private async Task DismissUpdateNoticeAsync()
    {
        var latestVersion = NormalizeVersion(_updateStatus?.LatestVersion);
        if (string.IsNullOrWhiteSpace(latestVersion))
            return;

        _dismissedUpdateVersion = latestVersion;
        await LocalStorage.SetAsync(DismissedUpdateVersionStorageKey, latestVersion);
        await InvokeAsync(StateHasChanged);
    }

    private async Task<ProbeResult> ProbeCurrentApiEndpointAsync(string relativePath, CancellationToken ct)
    {
        using var linkedCts = CancellationTokenSource.CreateLinkedTokenSource(ct);
        linkedCts.CancelAfter(TimeSpan.FromSeconds(4));

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, relativePath);
            using var response = await Http.SendAsync(request, HttpCompletionOption.ResponseHeadersRead, linkedCts.Token);

            return response.IsSuccessStatusCode
                ? new ProbeResult(ApiProbeStatus.Healthy, (int)response.StatusCode)
                : new ProbeResult(ApiProbeStatus.Unhealthy, (int)response.StatusCode);
        }
        catch (OperationCanceledException) when (!ct.IsCancellationRequested)
        {
            return new ProbeResult(ApiProbeStatus.Unreachable);
        }
        catch (HttpRequestException)
        {
            return new ProbeResult(ApiProbeStatus.Unreachable);
        }
    }

    private static string GetIndicatorClass(ApiProbeStatus status)
        => status switch
        {
            ApiProbeStatus.Healthy => "health-indicator is-healthy",
            ApiProbeStatus.Unhealthy => "health-indicator is-unhealthy",
            ApiProbeStatus.Unreachable => "health-indicator is-unreachable",
            _ => "health-indicator is-unknown"
        };

    private static string GetIndicatorTitle(string name, ApiProbeStatus status)
        => status switch
        {
            ApiProbeStatus.Healthy => $"{name}: healthy",
            ApiProbeStatus.Unhealthy => $"{name}: unhealthy",
            ApiProbeStatus.Unreachable => $"{name}: unreachable",
            _ => $"{name}: checking"
        };

    private static string GetUpdateNoticeTitle(UpdateStatusResult status)
    {
        var latestVersion = string.IsNullOrWhiteSpace(status.LatestVersion)
            ? "latest"
            : $"v{status.LatestVersion}";
        var currentVersion = string.IsNullOrWhiteSpace(status.CurrentVersion)
            ? "current version"
            : $"v{status.CurrentVersion}";

        return string.IsNullOrWhiteSpace(status.ReleaseTitle)
            ? $"A newer version is available. You are on {currentVersion}. Open release {latestVersion}."
            : $"A newer version is available. You are on {currentVersion}. Open release {latestVersion}: {status.ReleaseTitle}.";
    }

    private static string NormalizeVersion(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var normalized = value.Trim();
        if (normalized.StartsWith("v", StringComparison.OrdinalIgnoreCase))
            normalized = normalized[1..];

        return normalized;
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;

        if (_healthPollCts is null)
            return;

        _healthPollCts.Cancel();

        if (_healthPollTask is not null)
        {
            try
            {
                await _healthPollTask;
            }
            catch (OperationCanceledException)
            {
                // expected
            }
        }

        if (_updatePollTask is not null)
        {
            try
            {
                await _updatePollTask;
            }
            catch (OperationCanceledException)
            {
                // expected
            }
        }

        _healthPollCts.Dispose();
        _healthPollCts = null;
    }

    private static bool IsArchivePath(string? absoluteUri)
    {
        if (string.IsNullOrWhiteSpace(absoluteUri))
            return false;

        if (!Uri.TryCreate(absoluteUri, UriKind.Absolute, out var uri))
            return false;

        var normalized = uri.AbsolutePath.Trim('/');
        return string.Equals(normalized, "archive", StringComparison.OrdinalIgnoreCase);
    }
}
