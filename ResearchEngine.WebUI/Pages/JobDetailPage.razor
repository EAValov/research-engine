    private static bool IsTerminalStatus(string? s)
        => s is not null && (s.Equals("Completed", StringComparison.OrdinalIgnoreCase)
                          || s.Equals("Failed", StringComparison.OrdinalIgnoreCase)
                          || s.Equals("Canceled", StringComparison.OrdinalIgnoreCase));

    private static string FormatTime(DateTimeOffset dto)
        => dto.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");

    private static string ShortId(Guid id) => id.ToString("N")[..8];

    private static string DisplayModelName(string? value)
        => string.IsNullOrWhiteSpace(value) ? "Not recorded" : value.Trim();

    private static bool IsHttpUrl(string text)
    {
        if (!Uri.TryCreate(text, UriKind.Absolute, out var uri))
            return false;

        return uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps;
    }

    private static bool TryNormalizeHttpUrl(string text, out string normalized)
    {
        normalized = string.Empty;
        if (!Uri.TryCreate(text, UriKind.Absolute, out var uri))
            return false;

        if (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps)
            return false;

        normalized = uri.GetComponents(UriComponents.HttpRequestUrl, UriFormat.SafeUnescaped).TrimEnd('/');
        if (string.IsNullOrWhiteSpace(normalized))
            normalized = uri.GetComponents(UriComponents.HttpRequestUrl, UriFormat.SafeUnescaped);

        return true;
    }

    private static string BuildSourceKey(string sourceReference, Guid groupKey)
    {
        var trimmed = (sourceReference ?? string.Empty).Trim();
        if (TryNormalizeHttpUrl(trimmed, out var normalizedUrl))
            return $"url:{normalizedUrl}";

        if (!string.IsNullOrWhiteSpace(trimmed))
            return $"ref:{trimmed}";

        return $"group:{groupKey:N}";
    }

    private static string GetTopReferenceForExport(LearningGroupCardDto? group, Guid learningId)
    {
        if (group?.Evidence is not null)
        {
            foreach (var ev in group.Evidence)
            {
                var reference = (ev.SourceReference ?? string.Empty).Trim();
                if (string.IsNullOrWhiteSpace(reference))
                    continue;

                if (IsHttpUrl(reference))
                    return reference;
            }

            var first = group.Evidence
                .Select(x => (x.SourceReference ?? string.Empty).Trim())
                .FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));

            if (!string.IsNullOrWhiteSpace(first))
                return first;
        }

        return $"learning:{learningId:N}";
    }

    private static string ComposeMarkdown(SynthesisDto synthesis)
    {
        var sections = (synthesis.Sections ?? Array.Empty<SynthesisSectionDto>())
            .OrderBy(s => s.Index)
            .ToList();

        if (sections.Count == 0)
            return string.Empty;

        var parts = new List<string>(capacity: sections.Count * 2);

        foreach (var s in sections)
        {
            var title = string.IsNullOrWhiteSpace(s.Title) ? "Section" : s.Title.Trim();
            parts.Add($"## {title}");

            if (!string.IsNullOrWhiteSpace(s.ContentMarkdown))
                parts.Add(s.ContentMarkdown.Trim());
            else if (!string.IsNullOrWhiteSpace(s.Summary))
                parts.Add(s.Summary.Trim());
            else
                parts.Add("_No content._");
        }

        return string.Join("\n\n", parts);
    }

    public async ValueTask DisposeAsync()
    {
        await StopSynthesisWatchAsync();
        await StopStreamAsync();
    }
}

