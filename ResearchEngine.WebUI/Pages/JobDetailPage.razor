    private static bool TryGetRepresentativeSourceReference(LearningGroupCardDto group, out string sourceReference)
    {
        sourceReference = string.Empty;
        if (group.Evidence is null || group.Evidence.Count == 0)
            return false;

        var representativeEvidence = group.Evidence
            .FirstOrDefault(x => x.LearningId == group.RepresentativeLearningId);

        if (representativeEvidence is not null)
        {
            var representativeReference = (representativeEvidence.SourceReference ?? string.Empty).Trim();
            if (!string.IsNullOrWhiteSpace(representativeReference))
            {
                sourceReference = representativeReference;
                return true;
            }
        }

        foreach (var ev in group.Evidence)
        {
            var reference = (ev.SourceReference ?? string.Empty).Trim();
            if (string.IsNullOrWhiteSpace(reference))
                continue;

            sourceReference = reference;
            return true;
        }

        return false;
    }

