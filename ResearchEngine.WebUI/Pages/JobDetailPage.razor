        if (groupRes.IsSuccess && groupRes.Data is not null)
        {
            var group = groupRes.Data;

            _highlightLearningId = group.RepresentativeLearningId;

            if (TryGetRepresentativeSourceReference(group, out var sourceReference))
            {
                _focusLearningSourceReference = sourceReference;
                _learningsFilter = sourceReference;
            }
            else
