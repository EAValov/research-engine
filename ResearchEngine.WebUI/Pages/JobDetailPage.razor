    private static bool IsSynthesisActiveStatus(string? status)
        => status is not null && (status.Equals("Created", StringComparison.OrdinalIgnoreCase)
                               || status.Equals("Running", StringComparison.OrdinalIgnoreCase));

    private void ApplyLatestSynthesis(SynthesisDto synth, bool markUpdated)
    {
        _latestSynthesis = synth;
        _synthesisMarkdown = ComposeMarkdown(synth);
        _synthesisLoadedOnce = true;
        _synthesisEmpty = string.IsNullOrWhiteSpace(_synthesisMarkdown);

        if (markUpdated)
            _reportUpdatedAt = DateTimeOffset.Now;
    }

    private async Task StartSynthesisWatchAsync(Guid synthesisId)
    {
        if (_watchingSynthesisId == synthesisId && _synthesisWatchTask is { IsCompleted: false })
            return;

        await StopSynthesisWatchAsync();

        _watchingSynthesisId = synthesisId;
        _synthesisWatchCts = new CancellationTokenSource();
        _synthesisWatchTask = WatchSynthesisAsync(synthesisId, _synthesisWatchCts.Token);
    }

    private async Task StopSynthesisWatchAsync()
    {
        var cts = _synthesisWatchCts;
        var task = _synthesisWatchTask;

        _synthesisWatchCts = null;
        _synthesisWatchTask = null;
        _watchingSynthesisId = null;

        try { cts?.Cancel(); } catch { }

        if (task is not null)
        {
            try { await task; } catch { }
        }

        try { cts?.Dispose(); } catch { }
    }

    private async Task WatchSynthesisAsync(Guid synthesisId, CancellationToken ct)
    {
        var attempts = 0;

        try
        {
            while (!ct.IsCancellationRequested && attempts++ < 600) // ~15 min at 1.5s interval
            {
                SynthesisDto? synth = null;

                try
                {
                    synth = await Api.SynthesesGET2Async(synthesisId, ct);
                }
                catch (ApiException ex) when (ex.StatusCode == 404)
                {
                    // Not visible yet. Keep polling.
                }
                catch (OperationCanceledException)
                {
                    break;
                }
                catch
                {
                    // Best-effort watcher; do not break on transient failures.
                }

                if (synth is not null)
                {
                    var status = synth.Status?.Trim() ?? string.Empty;

                    if (string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase))
                    {
                        await InvokeAsync(async () =>
                        {
                            ApplyLatestSynthesis(synth, markUpdated: true);
                            _synthesisLoading = false;
                            _iterError = null;
                            _createDialogOpen = false;

                            _selectedSynthesisId = null;
                            _selectedSynthesisError = null;
                            _retryOpenId = null;

                            await ReloadEventsAsync();
                            StateHasChanged();
                        });
                        return;
                    }

                    if (string.Equals(status, "Failed", StringComparison.OrdinalIgnoreCase))
                    {
                        await InvokeAsync(async () =>
                        {
                            _synthesisLoading = false;
                            _iterError = new ApiError(ApiErrorKind.Unexpected, "Synthesis finished with status: Failed.");
                            await ReloadEventsAsync();
                            StateHasChanged();
                        });
                        return;
                    }

                    await InvokeAsync(() =>
                    {
                        _latestSynthesis = synth;
                        _synthesisLoadedOnce = true;
                        _synthesisLoading = true;
                        StateHasChanged();
                    });
                }

                if (attempts % 3 == 0)
                    await InvokeAsync(ReloadEventsAsync);

                await Task.Delay(1500, ct);
            }
        }
        catch (OperationCanceledException)
        {
            // expected on cancellation
        }
        finally
        {
            if (_watchingSynthesisId == synthesisId)
            {
                try { _synthesisWatchCts?.Dispose(); } catch { }
                _synthesisWatchCts = null;
                _synthesisWatchTask = null;
                _watchingSynthesisId = null;
            }
        }
    }

    private string BuildOverridesSummary()
    {
