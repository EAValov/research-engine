@page "/jobs/{JobId:guid}"
@using ResearchEngine.WebUI.Api
@using ResearchEngine.WebUI.Components.Common
@using ResearchEngine.WebUI.Components.Evidence
@using ResearchEngine.WebUI.Components.Synthesis
@using ResearchEngine.WebUI.Services
@using static ResearchEngine.WebUI.Services.JobEventsClient
@implements IAsyncDisposable
@inject IResearchApiClient Api
@inject JobFacade JobFacade
@inject JobEventsClient EventsClient
@inject SynthesisFacade SynthesisFacade
@inject SynthesisHistoryFacade SynthesisHistory
@inject SynthesisIterationFacade Iteration
@inject OverridesStore Overrides
@inject LearningGroupFacade LearningGroups
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Job</PageTitle>

@if (_isJobLoading)
{
    <p aria-live="polite">Loading job…</p>
}
else if (_jobError is not null)
{
    <ErrorBanner Error="_jobError" OnRetry="LoadAllAsync" />
}
else if (_job is null)
{
    <p>Job not found.</p>
}
else
{
    <section class="job-card" aria-label="Job details">
        <div class="row">
            <div class="label">Query</div>
            <div class="value">
                <strong>@_job.Query</strong>
            </div>
        </div>

        <div class="row">
            <div class="label">Status</div>
            <div class="value">
                <span class="pill">@CurrentStatusChip</span>
                @if (IsEffectivelyRunning)
                {
                    <span class="spinner status-spinner" aria-hidden="true"></span>
                }
                @if (!string.IsNullOrWhiteSpace(CurrentStage))
                {
                    <span class="stage">@CurrentStage</span>
                }

                @if (_streamError is not null && !IsTerminal)
                {
                    <span class="pill warn" title="Live stream disconnected. Will retry.">Live: error</span>
                }
            </div>
        </div>

        <div class="row">
            <div class="label">Created</div>
            <div class="value">@FormatTime(_job.CreatedAt)</div>
        </div>

        @if (_job.ArchivedAt is DateTimeOffset archivedAt)
        {
            <div class="row">
                <div class="label">Archived</div>
                <div class="value">@FormatTime(archivedAt)</div>
            </div>
        }

        <div class="toolbar" role="toolbar" aria-label="Job actions">
            <button class="toolbtn" type="button" @onclick="ToggleEvidence" aria-haspopup="dialog">
                Evidence
            </button>

            <button class="secondarybtn" type="button" @onclick="() => _historyOpen = true" aria-haspopup="dialog">
                History
            </button>

            @if (CanNewSynthesis)
            {
                <button class="secondarybtn" type="button" @onclick="OpenCreateDialog" aria-haspopup="dialog">
                    New synthesis
                </button>

                <button class="secondarybtn"
                        type="button"
                        @onclick="ExportSynthesisAsync"
                        disabled="@string.IsNullOrWhiteSpace(_synthesisMarkdown)">
                    Export
                </button>
            }

            @if (IsRunning)
            {
                <button class="dangerbtn"
                        type="button"
                        disabled="@_cancelInFlight"
                        @onclick="CancelAsync">
                    @(_cancelInFlight ? "Canceling…" : "Cancel job")
                </button>
            }

            <span class="toolbar-spacer" aria-hidden="true"></span>

            @if (IsArchived)
            {
                <button class="secondarybtn"
                        type="button"
                        disabled="@_archiveInFlight"
                        @onclick="UnarchiveAsync">
                    @(_archiveInFlight ? "Restoring…" : "Restore to recent")
                </button>

                <button class="dangerbtn"
                        type="button"
                        disabled="@_deleteInFlight"
                        @onclick="RequestDeleteArchivedConfirm">
                    @(_deleteInFlight ? "Deleting…" : "Delete")
                </button>
            }
            else
            {
                <button class="secondarybtn"
                        type="button"
                        disabled="@_archiveInFlight"
                        @onclick="RequestArchiveConfirm">
                    @(_archiveInFlight ? "Moving…" : "Move to archive")
                </button>
            }
        </div>

        @if (_cancelError is not null)
        {
            <ErrorBanner Error="_cancelError" OnRetry="CancelAsync" />
        }

        @if (_archiveError is not null)
        {
            <ErrorBanner Error="_archiveError" OnRetry="RetryArchiveActionAsync" />
        }

        @if (_deleteError is not null)
        {
            <ErrorBanner Error="_deleteError" OnRetry="DeleteArchivedAsync" />
        }
    </section>

    <!-- MAIN CENTER: REPORT -->
    <section class="report" aria-label="Report">
        <div class="report-head">
            <div class="report-title-row">
                <h2 class="h2 report-title">Report</h2>
                @if (CurrentReportId is Guid reportId)
                {
                    <span class="mono report-id">@ShortId(reportId)</span>
                }
                @if (ActiveSynthesis is not null && !string.IsNullOrWhiteSpace(ActiveSynthesis.Status))
                {
                    <span class="pill">@ActiveSynthesis.Status</span>
                    @if (IsSynthesisActiveStatus(ActiveSynthesis.Status))
                    {
                        <span class="spinner status-spinner" aria-hidden="true"></span>
                    }
                }
            </div>

            <div class="report-meta" aria-live="polite">
                @if (ActiveSynthesis is not null)
                {
                    <div class="report-meta-line">
                        <span>Completed: @FormatTime(ActiveSynthesis.CompletedAt ?? DateTime.Now)</span>
                    </div>
                    <div class="report-meta-line">
                        <span>Chat: @DisplayModelName(ActiveSynthesis.ChatModelName)</span>
                    </div>
                    <div class="report-meta-line">
                        <span>Embeddings: @DisplayModelName(ActiveSynthesis.EmbeddingModelName)</span>
                    </div>
                }

                @if (_selectedSynthesisId is not null)
                {
                    <div class="report-meta-line">
                        <button class="secondarybtn" type="button" @onclick="BackToLatestAsync">
                            Back to latest
                        </button>
                    </div>
                }

                @if (_reportUpdatedAt is not null)
                {
                    <div class="report-meta-line">
                        <span class="toast">Report updated</span>
                    </div>
                }
            </div>
        </div>

        @if (_iterBusy)
        {
            <div class="loader" aria-live="polite">
                <span class="spinner" aria-hidden="true"></span>
                <strong>Generating new synthesis…</strong>
            </div>
        }

        @if (_iterError is not null && _lastCreateInput is not null)
        {
            <ErrorBanner Error="_iterError" OnRetry="RetryIterationAsync" />
        }

        @if (_selectedSynthesisError is not null)
        {
            <ErrorBanner Error="_selectedSynthesisError" OnRetry="RetrySelectedOpenAsync" />
        }
        else if (_selectedSynthesisId is not null)
        {
            @if (_selectedLoading)
            {
                <div class="loader" aria-live="polite">
                    <span class="spinner" aria-hidden="true"></span>
                    <span>Loading synthesis…</span>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_synthesisMarkdown))
            {
                <MarkdownView Markdown="@_synthesisMarkdown"
                              OnOpenInLearnings="OpenLearningInDrawer" />
            }
            else
            {
                <p class="muted">No report content.</p>
            }
        }
        else if (!IsCompleted && !_iterBusy)
        {
            <p class="muted">Report will appear when the job completes.</p>
        }
        else if (_synthesisLoading && !_iterBusy)
        {
            <div class="loader" aria-live="polite">
                <span class="spinner" aria-hidden="true"></span>
                <span>Loading report…</span>
            </div>
        }
        else if (_synthesisError is not null && !_iterBusy)
        {
            <ErrorBanner Error="_synthesisError" OnRetry="LoadLatestSynthesisAsync" />
        }
        else if (_synthesisEmpty && !_iterBusy)
        {
            <p>No synthesis available yet.</p>
        }
        else if (!string.IsNullOrWhiteSpace(_synthesisMarkdown))
        {
            <MarkdownView Markdown="@_synthesisMarkdown"
                          OnOpenInLearnings="OpenLearningInDrawer" />
        }
    </section>

    <!-- PROGRESS MOVED TO BOTTOM (COLLAPSIBLE) -->
    <section class="progress dock" aria-label="Progress">
        <div class="progress-head">
            <h2 class="h2">Progress</h2>

            <div class="progress-actions">
                <button class="secondarybtn"
                        type="button"
                        @onclick="ToggleProgressExpanded"
                        aria-expanded="@_progressExpanded">
                    @(_progressExpanded ? "Collapse" : "Expand")
                </button>
            </div>
        </div>

        @if (_eventsError is not null)
        {
            <ErrorBanner Error="_eventsError" OnRetry="ReloadEventsAsync" />
        }
        else if (_isEventsLoading)
        {
            <p aria-live="polite">Loading events…</p>
        }
        else if (_events.Count == 0)
        {
            <p class="muted">No events yet.</p>
        }
        else if (!_progressExpanded)
        {
            var last = _events[^1];
            <div class="last-event" tabindex="0">
                <div class="t-head">
                    <span class="t-time">@FormatTime(last.Timestamp)</span>
                    <span class="t-stage">@last.Stage</span>
                </div>
                <div class="t-msg">@last.Message</div>
            </div>
        }
        else
        {
            <div class="progress-controls">
                <label class="check">
                    <input type="checkbox" @bind="_followTail" />
                    Follow tail
                </label>
            </div>

            <ul class="timeline" @ref="_timelineRef" aria-label="Job event timeline">
                @foreach (var ev in _events)
                {
                    <li class="timeline-item" tabindex="0">
                        <div class="t-head">
                            <span class="t-time">@FormatTime(ev.Timestamp)</span>
                            <span class="t-stage">@ev.Stage</span>
                        </div>
                        <div class="t-msg">@ev.Message</div>
                    </li>
                }
            </ul>
        }
    </section>

    <EvidenceDrawer JobId="JobId"
                    @bind-IsOpen="_evidenceOpen"
                    InitialTab="@_evidenceTab"
                    ActiveTab="@_evidenceTab"
                    ActiveTabChanged="tab => _evidenceTab = tab"
                    HighlightLearningId="@_highlightLearningId"
                    FocusSourceReference="@_focusLearningSourceReference"
                    SourcesFilter="@_sourcesFilter"
                    SourcesFilterChanged="value => _sourcesFilter = value"
                    LearningsFilter="@_learningsFilter"
                    LearningsFilterChanged="OnLearningsFilterChanged"
                    LearningsLoadedCount="@_learningsLoadedCount"
                    LearningsLoadedCountChanged="count => _learningsLoadedCount = count"
                    RestrictToLearningGroupId="@_restrictToLearningGroupId" />

    <SynthesisHistoryDrawer JobId="JobId"
                            IsOpen="_historyOpen"
                            IsOpenChanged="v => _historyOpen = v"
                            CurrentSynthesisId="CurrentSynthesisIdForDrawer"
                            OpenSynthesis="OpenSynthesisAsync"
                            UseAsBase="UseAsBaseAsync"
                            DeleteSynthesis="OnSynthesisDeletedAsync" />

    <CreateSynthesisDialog IsOpen="_createDialogOpen"
                           IsOpenChanged="v => _createDialogOpen = v"
                           HasOverrides="@Overrides.HasAny(JobId)"
                           OverridesSummary="@BuildOverridesSummary()"
                           Busy="_iterBusy"
                           Error="_iterError"
                           PrefillInstructions="@_prefillInstructions"
                           PrefillOutline="@_prefillOutline"
                           BaseSynthesisId="_baseSynthesisId"
                           OnCreateAndRun="CreateAndRunSynthesisAsync" />

    @if (HasPendingConfirm)
    {
        <div class="confirm-overlay" @onclick="CancelPendingConfirm">
            <section class="confirm-dialog"
                     role="dialog"
                     aria-modal="true"
                     aria-labelledby="jobConfirmTitle"
                     @onclick:stopPropagation="true"
                     @onkeydown="OnConfirmKeyDown"
                     tabindex="-1">
                <div class="confirm-head">
                    <h3 id="jobConfirmTitle">@ConfirmTitle</h3>
                    <button type="button" class="confirm-close" @onclick="CancelPendingConfirm" aria-label="Close">×</button>
                </div>

                <p class="confirm-message">@ConfirmMessage</p>

                <div class="confirm-actions">
                    <button type="button" class="secondarybtn" @onclick="CancelPendingConfirm">Cancel</button>
                    <button type="button" class="dangerbtn" @onclick="ConfirmPendingActionAsync">@ConfirmAcceptLabel</button>
                </div>
            </section>
        </div>
    }
}

@code {
    [Parameter] public Guid JobId { get; set; }

    private enum JobConfirmAction
    {
        None,
        Archive,
        DeleteArchived
    }

    private bool _isJobLoading = true;
    private ApiError? _jobError;
    private GetResearchJobResponse? _job;

    private bool _evidenceOpen;
    private string _evidenceTab = "sources";
    private Guid? _highlightLearningId;
    private string? _focusLearningSourceReference;
    private Guid? _restrictToLearningGroupId;
    private string _sourcesFilter = "";
    private string _learningsFilter = "";
    private int _learningsLoadedCount = 25;

    private bool _historyOpen;

    private bool _isEventsLoading;
    private ApiError? _eventsError;
    private ApiError? _streamError;

    private readonly List<PersistedJobEvent> _events = new();

    private string? _terminalStatus;
    private Guid? _doneSynthesisId;

    private ElementReference _timelineRef;
    private bool _followTail = true;
    private bool _progressExpanded;

    private CancellationTokenSource? _streamCts;
    private CancellationTokenSource? _synthesisWatchCts;
    private Task? _synthesisWatchTask;
    private Guid? _watchingSynthesisId;

    private bool _cancelInFlight;
    private ApiError? _cancelError;

    private bool _archiveInFlight;
    private ApiError? _archiveError;

    private bool _deleteInFlight;
    private ApiError? _deleteError;

    private JobConfirmAction _pendingConfirm = JobConfirmAction.None;

    private bool _synthesisLoading;
    private ApiError? _synthesisError;
    private bool _synthesisEmpty;
    private SynthesisDto? _latestSynthesis;
    private SynthesisDto? _selectedSynthesis;
    private string _synthesisMarkdown = string.Empty;
    private bool _synthesisLoadedOnce;

    private Guid? _selectedSynthesisId;
    private bool _selectedLoading;
    private ApiError? _selectedSynthesisError;
    private Guid? _retryOpenId;

    private bool _createDialogOpen;
    private bool _iterBusy;
    private ApiError? _iterError;
    private CreateSynthesisInput? _lastCreateInput;
    private DateTimeOffset? _reportUpdatedAt;

    private string? _prefillInstructions;
    private string? _prefillOutline;
    private Guid? _baseSynthesisId;

    private bool IsTerminal =>
        string.Equals(_terminalStatus, "Completed", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(_terminalStatus, "Failed", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(_terminalStatus, "Canceled", StringComparison.OrdinalIgnoreCase);

    private bool IsRunning =>
        string.Equals(_job?.Status, "Pending", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(_job?.Status, "Running", StringComparison.OrdinalIgnoreCase);

    private bool HasNonCreatedEvents
        => _events.Any(e => !string.Equals(e.Stage, "Created", StringComparison.OrdinalIgnoreCase));

    private bool IsEffectivelyRunning
        => !IsTerminal && (HasNonCreatedEvents || string.Equals(_job?.Status?.ToString(), "Running", StringComparison.OrdinalIgnoreCase));

    private bool IsCompleted =>
        string.Equals(_terminalStatus, "Completed", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(_job?.Status?.ToString(), "Completed", StringComparison.OrdinalIgnoreCase);

    private bool IsCanceled =>
        string.Equals(_terminalStatus, "Canceled", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(_job?.Status?.ToString(), "Canceled", StringComparison.OrdinalIgnoreCase);

    private bool IsArchived => _job?.ArchivedAt is not null;
    private bool HasPendingConfirm => _pendingConfirm != JobConfirmAction.None;

    private string ConfirmTitle => _pendingConfirm switch
    {
        JobConfirmAction.Archive => "Move job to archive?",
        JobConfirmAction.DeleteArchived => "Delete archived job?",
        _ => string.Empty
    };

    private string ConfirmMessage => _pendingConfirm switch
    {
        JobConfirmAction.Archive => "This job will be removed from Recent jobs and shown under Archived jobs.",
        JobConfirmAction.DeleteArchived => "This will soft-delete the archived job and hide it from the app lists.",
        _ => string.Empty
    };

    private string ConfirmAcceptLabel => _pendingConfirm switch
    {
        JobConfirmAction.Archive => "Move to archive",
        JobConfirmAction.DeleteArchived => "Delete",
        _ => "Confirm"
    };

    private string CurrentStatusChip
        => _terminalStatus
        ?? (IsEffectivelyRunning ? "Running" : (_job?.Status?.ToString() ?? "Unknown"));

    private string CurrentStage
        => _events.Count == 0 ? "" : _events[^1].Stage;

    private bool CanNewSynthesis
        => IsCompleted || IsCanceled || (_latestSynthesis is not null) || (_synthesisLoadedOnce && !_synthesisEmpty);

    private Guid? CurrentSynthesisIdForDrawer => _selectedSynthesisId ?? _latestSynthesis?.Id;
    private SynthesisDto? ActiveSynthesis => _selectedSynthesisId is not null ? _selectedSynthesis : _latestSynthesis;
    private Guid? CurrentReportId => _selectedSynthesisId ?? _latestSynthesis?.Id;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        await StopSynthesisWatchAsync();

        _jobError = null;
        _eventsError = null;
        _streamError = null;
        _cancelError = null;
        _archiveError = null;
        _deleteError = null;

        _synthesisError = null;
        _synthesisEmpty = false;
        _latestSynthesis = null;
        _selectedSynthesis = null;
        _synthesisMarkdown = string.Empty;
        _synthesisLoadedOnce = false;

        _selectedSynthesisId = null;
        _selectedLoading = false;
        _selectedSynthesisError = null;
        _retryOpenId = null;

        _highlightLearningId = null;
        _focusLearningSourceReference = null;
        _restrictToLearningGroupId = null;
        _sourcesFilter = "";
        _learningsFilter = "";
        _learningsLoadedCount = 25;

        _iterError = null;
        _iterBusy = false;
        _lastCreateInput = null;
        _reportUpdatedAt = null;

        _isJobLoading = true;

        try
        {
            _job = await Api.JobsGET2Async(JobId);

            var statusText = _job.Status?.ToString();
            _terminalStatus = IsTerminalStatus(statusText) ? statusText : null;

            await ReloadEventsAsync();

            await StopStreamAsync();

            if (!IsTerminal)
            {
                _streamCts = new CancellationTokenSource();

                await EventsClient.StartAsync(
                    jobId: JobId,
                    onItem: HandleStreamItemAsync,
                    onError: HandleStreamErrorAsync,
                    ct: _streamCts.Token);
            }

            if (IsCompleted)
            {
                await LoadLatestSynthesisAsync();
            }
        }
        catch (Exception ex)
        {
            _jobError = ApiErrorMapper.Map(ex);
        }
        finally
        {
            _isJobLoading = false;
        }
    }

    private async Task ReloadEventsAsync()
    {
        _isEventsLoading = true;
        _eventsError = null;

        _events.Clear();

        var res = await JobFacade.GetEventsAsync(JobId);
        if (!res.IsSuccess)
        {
            _eventsError = res.Error;
            _isEventsLoading = false;
            return;
        }

        foreach (var dto in res.Data!)
            _events.Add(new PersistedJobEvent(dto.Id, dto.Timestamp, dto.Stage, dto.Message));

        _events.Sort(static (a, b) => a.Id.CompareTo(b.Id));
        _isEventsLoading = false;
        _streamError = null;

        if (_events.Count > 0)
        {
            var lastStage = _events[^1].Stage;
            if (IsTerminalStatus(lastStage))
            {
                _terminalStatus = lastStage;
                if (_job is not null)
                    _job.Status = lastStage;
            }
            else if (!string.Equals(lastStage, "Created", StringComparison.OrdinalIgnoreCase)
                     && !IsTerminalStatus(_job?.Status))
            {
                _terminalStatus = "Running";
                if (_job is not null)
                    _job.Status = "Running";
            }
        }

        if (_followTail && _progressExpanded && _events.Count > 0)
        {
            _ = InvokeAsync(async () =>
            {
                StateHasChanged();
                await Task.Yield();
                try { await JS.InvokeVoidAsync("researchEngine.jobEvents.scrollToBottom", _timelineRef); } catch { }
            });
        }
    }

    private Task HandleStreamErrorAsync(ApiError err)
    {
        _streamError = err;
        return InvokeAsync(StateHasChanged);
    }

    private async Task HandleStreamItemAsync(JobStreamItem item)
    {
        if (item.Kind == JobStreamKind.Event && item.Event is not null)
        {
            _streamError = null;

            if (IsTerminalStatus(item.Event.Stage))
            {
                _terminalStatus = item.Event.Stage;
                if (_job is not null)
                    _job.Status = item.Event.Stage;
            }
            else if (!string.Equals(item.Event.Stage, "Created", StringComparison.OrdinalIgnoreCase))
            {
                _terminalStatus = "Running";
                if (_job is not null && !IsTerminalStatus(_job.Status))
                    _job.Status = "Running";
            }

            // Extra guard to avoid UI duplicates even if the stream replays.
            // (JobEventsClient should already dedupe.)
            if (_events.Count == 0 || _events[^1].Id < item.Event.Id || !_events.Any(e => e.Id == item.Event.Id))
            {
                _events.Add(item.Event);
                _events.Sort(static (a, b) => a.Id.CompareTo(b.Id));
            }

            await InvokeAsync(async () =>
            {
                StateHasChanged();
                await Task.Yield();

                try
                {
                    if (_progressExpanded)
                    {
                        if (_followTail)
                            await JS.InvokeVoidAsync("researchEngine.jobEvents.scrollToBottom", _timelineRef);
                        else
                            await JS.InvokeVoidAsync("researchEngine.jobEvents.scrollIfNearBottom", _timelineRef);
                    }
                }
                catch { }
            });

            return;
        }

        if (item.Kind == JobStreamKind.Done && item.Done is not null)
        {
            _terminalStatus = item.Done.Status;
            if (_job is not null)
                _job.Status = item.Done.Status;
            _doneSynthesisId = item.Done.SynthesisId;

            await InvokeAsync(async () =>
            {
                await StopStreamAsync();

                if (_watchingSynthesisId is null
                    || _doneSynthesisId is null
                    || _watchingSynthesisId == _doneSynthesisId)
                {
                    await StopSynthesisWatchAsync();
                }

                if (string.Equals(_terminalStatus, "Completed", StringComparison.OrdinalIgnoreCase))
                {
                    if (_selectedSynthesisId is null)
                        await LoadLatestSynthesisAsync();
                }

                StateHasChanged();
            });
        }
    }

    private async Task StopStreamAsync()
    {
        try { _streamCts?.Cancel(); } catch { }
        try { _streamCts?.Dispose(); } catch { }
        _streamCts = null;

        try { await EventsClient.StopAsync(); } catch { }
    }

    private async Task LoadLatestSynthesisAsync()
    {
        if (!IsCompleted) return;

        _synthesisLoading = true;
        _synthesisError = null;
        _synthesisEmpty = false;

        var res = await SynthesisFacade.GetLatestSynthesisAsync(JobId);
        if (!res.IsSuccess)
        {
            _synthesisError = res.Error;
            _synthesisLoading = false;
            return;
        }

        _latestSynthesis = res.Data;

        if (_latestSynthesis is null)
        {
            await StopSynthesisWatchAsync();
            _synthesisEmpty = true;
            _synthesisMarkdown = string.Empty;
            _synthesisLoading = false;
        }
        else
        {
            var status = _latestSynthesis.Status?.Trim() ?? string.Empty;

            if (IsSynthesisActiveStatus(status))
            {
                _synthesisMarkdown = ComposeMarkdown(_latestSynthesis);
                _synthesisEmpty = string.IsNullOrWhiteSpace(_synthesisMarkdown);
                _synthesisLoading = true;
                await StartSynthesisWatchAsync(_latestSynthesis.Id);
            }
            else
            {
                await StopSynthesisWatchAsync();
                ApplyLatestSynthesis(_latestSynthesis, markUpdated: false);
                _synthesisLoading = false;
            }
        }

        _synthesisLoadedOnce = true;
    }

    private async Task OpenSynthesisAsync(Guid synthesisId)
    {
        _selectedSynthesisId = synthesisId;
        _retryOpenId = synthesisId;
        _selectedSynthesisError = null;
        _selectedSynthesis = null;

        _selectedLoading = true;
        try
        {
            var res = await SynthesisHistory.GetSynthesisAsync(synthesisId);
            if (!res.IsSuccess)
            {
                _selectedSynthesisError = res.Error;
                return;
            }

            _selectedSynthesis = res.Data!;
            _synthesisMarkdown = ComposeMarkdown(_selectedSynthesis);
        }
        finally
        {
            _selectedLoading = false;
            StateHasChanged();
        }
    }

    private Task RetrySelectedOpenAsync()
    {
        if (_retryOpenId is null) return Task.CompletedTask;
        return OpenSynthesisAsync(_retryOpenId.Value);
    }

    private async Task BackToLatestAsync()
    {
        _selectedSynthesisId = null;
        _selectedSynthesis = null;
        _selectedSynthesisError = null;
        _retryOpenId = null;

        if (IsCompleted)
            await LoadLatestSynthesisAsync();

        StateHasChanged();
    }

    private async Task OnSynthesisDeletedAsync(Guid synthesisId)
    {
        if (_watchingSynthesisId == synthesisId)
            await StopSynthesisWatchAsync();

        if (_selectedSynthesisId == synthesisId)
        {
            _selectedSynthesisId = null;
            _selectedSynthesis = null;
            _selectedSynthesisError = null;
            _retryOpenId = null;
        }

        if (_latestSynthesis?.Id == synthesisId)
        {
            _latestSynthesis = null;
            _synthesisMarkdown = string.Empty;
            _synthesisEmpty = true;

            var latestRes = await SynthesisFacade.GetLatestSynthesisAsync(JobId);
            if (latestRes.IsSuccess && latestRes.Data is not null)
            {
                ApplyLatestSynthesis(latestRes.Data, markUpdated: false);
            }
            else if (!latestRes.IsSuccess)
            {
                _synthesisError = latestRes.Error;
            }
        }

        StateHasChanged();
    }

    private async Task UseAsBaseAsync(SynthesisDto s)
    {
        _prefillInstructions = string.IsNullOrWhiteSpace(s.Instructions) ? null : s.Instructions;
        _prefillOutline = string.IsNullOrWhiteSpace(s.Outline) ? null : s.Outline;
        _baseSynthesisId = s.Id;

        _iterError = null;
        _createDialogOpen = true;

        await InvokeAsync(StateHasChanged);
    }

    private async Task CreateAndRunSynthesisAsync(CreateSynthesisInput input)
    {
        _iterError = null;
        _iterBusy = true;
        _lastCreateInput = input;
        _reportUpdatedAt = null;

        _synthesisError = null;
        _synthesisEmpty = false;
        _synthesisLoading = true;

        try
        {
            var snapshot = Overrides.GetSnapshot(JobId);

            var res = await Iteration.CreateAndRunAsync(
                jobId: JobId,
                instructions: input.Instructions,
                outline: input.Outline,
                applyOverrides: input.ApplyOverrides,
                overrides: snapshot,
                parentSynthesisId: input.ParentSynthesisId,
                useLatestAsParent: input.UseLatestAsParent);

            if (!res.IsSuccess)
            {
                _iterError = res.Error;
                _synthesisLoading = false;
                return;
            }

            // Refresh events so the run progress shows immediately
            await ReloadEventsAsync();

            var terminal = res.Data!;
            var terminalStatus = terminal.Status?.Trim() ?? string.Empty;

            if (IsSynthesisActiveStatus(terminalStatus))
            {
                _createDialogOpen = false;
                _prefillInstructions = null;
                _prefillOutline = null;
                _baseSynthesisId = null;

                _selectedSynthesisId = null;
                _selectedSynthesisError = null;
                _retryOpenId = null;

                _synthesisLoading = true;
                _synthesisEmpty = true;
                _synthesisLoadedOnce = true;

                await StartSynthesisWatchAsync(terminal.SynthesisId);
                return;
            }

            if (!string.Equals(terminalStatus, "Completed", StringComparison.OrdinalIgnoreCase))
            {
                _iterError = new ApiError(ApiErrorKind.Unexpected, $"Synthesis finished with status: {terminal.Status}. {terminal.Message}");
                _synthesisLoading = false;
                return;
            }

            // Prefer direct fetch by id if available
            var synth = await Api.SynthesesGET2Async(terminal.SynthesisId);
            ApplyLatestSynthesis(synth, markUpdated: true);
            _synthesisLoading = false;

            _selectedSynthesisId = null;
            _selectedSynthesis = null;
            _selectedSynthesisError = null;
            _retryOpenId = null;

            _prefillInstructions = null;
            _prefillOutline = null;
            _baseSynthesisId = null;

            _createDialogOpen = false;
        }
        catch (Exception ex)
        {
            _iterError = ApiErrorMapper.Map(ex);
            _synthesisLoading = false;
        }
        finally
        {
            _iterBusy = false;
            StateHasChanged();
        }
    }

    private Task RetryIterationAsync()
    {
        if (_lastCreateInput is null) return Task.CompletedTask;
        return CreateAndRunSynthesisAsync(_lastCreateInput);
    }

    private Task RetryArchiveActionAsync()
        => IsArchived ? UnarchiveAsync() : ArchiveAsync();

    private void RequestArchiveConfirm()
    {
        if (_job is null || IsArchived || _archiveInFlight)
            return;

        _pendingConfirm = JobConfirmAction.Archive;
    }

    private void RequestDeleteArchivedConfirm()
    {
        if (_job is null || !IsArchived || _deleteInFlight)
            return;

        _pendingConfirm = JobConfirmAction.DeleteArchived;
    }

    private void CancelPendingConfirm()
    {
        _pendingConfirm = JobConfirmAction.None;
    }

    private Task OnConfirmKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            CancelPendingConfirm();

        return Task.CompletedTask;
    }

    private async Task ConfirmPendingActionAsync()
    {
        var action = _pendingConfirm;
        _pendingConfirm = JobConfirmAction.None;

        if (action == JobConfirmAction.Archive)
        {
            await ArchiveAsync();
            return;
        }

        if (action == JobConfirmAction.DeleteArchived)
            await DeleteArchivedAsync();
    }

    private async Task ArchiveAsync()
    {
        if (_job is null || IsArchived || _archiveInFlight)
            return;

        _archiveError = null;
        _archiveInFlight = true;

        try
        {
            var res = await JobFacade.ArchiveJobAsync(JobId);
            if (!res.IsSuccess)
            {
                _archiveError = res.Error;
                return;
            }

            if (_job is not null)
            {
                _job.ArchivedAt = DateTimeOffset.Now;
                _job.UpdatedAt = DateTimeOffset.Now;
            }
        }
        finally
        {
            _archiveInFlight = false;
            StateHasChanged();
        }
    }

    private async Task UnarchiveAsync()
    {
        if (_job is null || !IsArchived || _archiveInFlight)
            return;

        _archiveError = null;
        _archiveInFlight = true;

        try
        {
            var res = await JobFacade.UnarchiveJobAsync(JobId);
            if (!res.IsSuccess)
            {
                _archiveError = res.Error;
                return;
            }

            if (_job is not null)
            {
                _job.ArchivedAt = null;
                _job.UpdatedAt = DateTimeOffset.Now;
            }
        }
        finally
        {
            _archiveInFlight = false;
            StateHasChanged();
        }
    }

    private async Task DeleteArchivedAsync()
    {
        if (_job is null || !IsArchived || _deleteInFlight)
            return;

        _deleteError = null;
        _deleteInFlight = true;

        try
        {
            var res = await JobFacade.SoftDeleteJobAsync(JobId);
            if (!res.IsSuccess)
            {
                _deleteError = res.Error;
                return;
            }

            await StopSynthesisWatchAsync();
            await StopStreamAsync();
            Nav.NavigateTo("/archive");
        }
        finally
        {
            _deleteInFlight = false;
            StateHasChanged();
        }
    }

    private async Task CancelAsync()
    {
        if (!IsRunning || _cancelInFlight) return;

        _cancelError = null;
        _cancelInFlight = true;

        try
        {
            var res = await JobFacade.CancelJobAsync(JobId);
            if (!res.IsSuccess)
            {
                _cancelError = res.Error;
                return;
            }

            _terminalStatus = "Canceled";
            if (_job is not null)
                _job.Status = "Canceled";

            _synthesisLoading = false;
            await StopSynthesisWatchAsync();
            await StopStreamAsync();
            await ReloadEventsAsync();
        }
        finally
        {
            _cancelInFlight = false;
            StateHasChanged();
        }
    }

    private async Task OpenLearningInDrawer(Guid learningId)
