    private async Task ExportSynthesisAsync()
    {
        if (string.IsNullOrWhiteSpace(_synthesisMarkdown))
            return;

        var exportId = _selectedSynthesisId ?? _latestSynthesis?.Id ?? JobId;
        var fileName = $"synthesis-{ShortId(exportId)}.md";
        var exportMarkdown = _synthesisMarkdown;

        try
        {
            exportMarkdown = await BuildExportMarkdownAsync(_synthesisMarkdown);
        }
        catch
        {
            // Fall back to raw markdown if citation enrichment fails.
        }

        try
        {
            var exportDocument = BuildExportDocument(exportMarkdown, ActiveSynthesis);
            await JS.InvokeVoidAsync("researchEngine.downloadTextFile", fileName, exportDocument);
        }
        catch
        {
            // Keep page responsive if browser download fails.
        }
    }

    private async Task<string> BuildExportMarkdownAsync(string markdown)
    {
        var orderedIds = Citations.ExtractLearningIdsInAppearanceOrder(markdown);
        if (orderedIds.Count == 0)
            return markdown;

        try { await LearningGroups.PrefetchGroupsAsync(orderedIds); } catch { }

        var sourceIndexByKey = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        var citationIndexByLearningId = new Dictionary<Guid, int>();
        var sourceByIndex = new Dictionary<int, string>();
        var nextIndex = 1;

        foreach (var learningId in orderedIds)
        {
            LearningGroupCardDto? group = null;
            if (LearningGroups.TryGetCached(learningId, out var cached))
                group = cached;

            var groupKey = group?.GroupId ?? learningId;
            var sourceReference = GetTopReferenceForExport(group, learningId);
            var sourceKey = BuildSourceKey(sourceReference, groupKey);

            if (!sourceIndexByKey.TryGetValue(sourceKey, out var index))
            {
                index = nextIndex++;
                sourceIndexByKey[sourceKey] = index;
                sourceByIndex[index] = sourceReference;
            }

            citationIndexByLearningId[learningId] = index;
        }

        var rewritten = Citations.RewriteLearningCitationsToLabels(markdown, learningId =>
        {
            if (!citationIndexByLearningId.TryGetValue(learningId, out var index))
                return null;

            return index.ToString(System.Globalization.CultureInfo.InvariantCulture);
        });

        if (sourceByIndex.Count == 0)
            return rewritten;

        var sources = sourceByIndex
            .OrderBy(x => x.Key)
            .Select(x => $"{x.Key}. {x.Value}")
            .ToList();

        return $"{rewritten}\n\n## Sources\n\n{string.Join("\n", sources)}";
    }

    private string BuildExportDocument(string markdown, SynthesisDto? synthesis)
    {
        var heading = BuildExportHeading();
        var metadata = BuildExportMetadata(synthesis);
        var body = (markdown ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(body))
            return $"{heading}\n\n{metadata}";

        return $"{heading}\n\n{metadata}\n\n{body}";
    }

    private string BuildExportHeading()
    {
        var query = (_job?.Query ?? string.Empty)
            .Replace("\r", " ", StringComparison.Ordinal)
            .Replace("\n", " ", StringComparison.Ordinal)
            .Trim();

        if (string.IsNullOrWhiteSpace(query))
            query = "Research report";

        return $"# {query}";
    }

    private string BuildExportMetadata(SynthesisDto? synthesis)
    {
        var breadth = _job?.Breadth.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "Not recorded";
        var depth = _job?.Depth.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "Not recorded";
        DateTimeOffset? createdAt = synthesis?.CreatedAt ?? _job?.CreatedAt;
        var completedAt = synthesis?.CompletedAt;

        var createdText = createdAt is null ? "Not recorded" : FormatTime(createdAt.Value);
        var completedText = completedAt is null ? "Not completed" : FormatTime(completedAt.Value);

        return string.Join("\n", new[]
        {
            $"- Breadth: {breadth}",
            $"- Depth: {depth}",
            $"- Created: {createdText}",
            $"- Completed: {completedText}"
        });
    }

